
import hzui
type presets = hzui.presets;

inline struct DivProps {
    id: int;
    style?: hzui.DivStyle;
    presets?: []presets.Preset;
    ref?: ElementRef<hzui.DivElement>;
}

inline struct TextProps {
    id: int;
    style?: hzui.TextStyle;
    text: str;
    presets?: []presets.Preset;
    ref?: ElementRef<hzui.TextElement>;
}

inline struct CanvasProps {
    id: int;
    style?: hzui.DivStyle;
    presets?: []presets.Preset;
    ref?: ElementRef<hzui.CanvasElement>;
}

// The concrete renderer handle stored, type-erased, inside
// hzui.CanvasElement._handle. hzui never reads this -- only this app layer
// (here and in main.hz's renderCanvas callback) does, via
// TypeErasedBox.get<CanvasHandle>()/set<CanvasHandle>(). Both sides must
// agree on this exact type: TypeErasedBox has no runtime type tag.
struct CanvasHandle {
    canvas: mut gfx.Canvas;
}

// The concrete type stored, type-erased, inside hzui.CanvasElement._drawFn.
// Named so it can be used as a generic argument to TypeErasedBox<T> (a bare
// function-type literal there doesn't parse).
type CanvasDrawFn = (r: mut gfx.Renderer) => void;

struct ComponentInstance {
    id: int;

    templateComputed?: rx.Computed<none>;
    setupDone: bool = false;
    currentTemplate: (() => void) | null = null;
    propsVersion: rx.Reactive<int>;
    prevProps?: TypeErasedBox;
    instanceDataForCapturing?: TypeErasedBox;

    struct ComponentCache {
        id: int;
        component: ComponentInstance;
    }

    struct ElementCache {
        id: int;
        element: mut hzui.Element;
    }

    elementsById: []inline ElementCache = [];
    childComponents: []inline ComponentCache = [];
    newChildComponents: []inline ComponentCache = [];

    rootElement: hzui.DivElement;

    onMounted?: () => none;
    onUnmount?: () => none;

    mounted: bool = false;
    crashed: bool = false;
    crashInfo: sys.PanicInfo | none = none;

    fn getOrCreateDiv(id: int): mut hzui.DivElement {
        for n in this.elementsById {
            if n.id == id {
                assert(n.element is mut hzui.DivElement, "Div expected but other node type encountered");
                return n.element;
            }
        }
        let newElement = hzui.DivElement({ id: id, style: {} });
        this.elementsById.push({ id: id, element: newElement });
        return newElement;
    }

    fn getOrCreateText(id: int): mut hzui.TextElement {
        for n in this.elementsById {
            if n.id == id {
                assert(n.element is mut hzui.TextElement, "Text element expected but other node type encountered");
                return n.element;
            }
        }
        let newElement = hzui.TextElement({ id: id, text: "", style: {} });
        this.elementsById.push({ id: id, element: newElement });
        return newElement;
    }

    fn getOrCreateCanvas(id: int): mut hzui.CanvasElement {
        for n in this.elementsById {
            if n.id == id {
                assert(n.element is mut hzui.CanvasElement, "Canvas element expected but other node type encountered");
                return n.element;
            }
        }
        let newElement = hzui.CanvasElement({ id: id, style: {} });
        this.elementsById.push({ id: id, element: newElement });
        return newElement;
    }

    fn findChild(id: int): ComponentInstance | null {
        for n in this.childComponents {
            if n.id == id {
                return n.component;
            }
        }
        return null;
    }

    fn createChild(id: int): ComponentInstance {
        return ComponentInstance {
            id: id,
            rootElement: hzui.DivElement({
                id: id,
                style: {},
            }),
            propsVersion: rx.reactive<int>(0),
        };
    }
}

struct RenderContext {
    currentComponent: ComponentInstance;
    currentParent: hzui.DivElement;
}

struct InstanceData<TProps> {
    _props: TProps;
    _propsVersion: rx.Reactive<int>;

    fn props() {
        rx.get(this._propsVersion);
        return this._props;
    }
}

opaque struct UIContext {
    _mousePosCb: (() => Vec2);
    renderStack: []RenderContext = [];
    effectQueue: [](() => void) = [];
    rootComponent: ComponentInstance | null = null;
    rootTemplate: rx.Computed<none>;
    _framecount: rx.Reactive<int>;
    _deltaTime: rx.Reactive<real>;
    _timeNow: rx.Reactive<real>;
    _prevTime: real;

    mousePos: Vec2 = {};
    pmousePos: Vec2 = {};
    dmousePos: Vec2 = {};

    inline struct UIContextArgs {
        ui: ((ui: UIContext) => none);
        mousePos: () => Vec2;
    }

    fn constructor(args: UIContextArgs) {
        let ctx = UIContext {
            rootTemplate: rx.computed<none>(() => {}),
            _framecount: rx.reactive<int>(0),
            _deltaTime: rx.reactive<real>(0),
            _timeNow: rx.reactive<real>(0),
            _prevTime: time.now(),
            _mousePosCb: args.mousePos,
        };

        // UI Context depends on itself
        ctx.rootTemplate = rx.computed<none>(() => {
            args.ui(ctx);
        });

        return ctx;
    }

    fn framecount(): int {
        return this._framecount;
    }

    fn deltaTime(): real {
        return this._deltaTime;
    }

    fn now(): real {
        return this._timeNow;
    }

    fn applyHitTestAndScheduleEvents(element: hzui.Element, mousePos: Vec2): [](() => none) :: final {
        let events: [](() => none) = [];

        if element is hzui.DivElement {
            let pos = element.position();
            let size = element.size();

            let hovered = false;
            if pos && size {
                hovered = 
                    (mousePos.x > pos.x) && (mousePos.x < (pos.x + size.x)) &&
                    (mousePos.y > pos.y) && (mousePos.y < (pos.y + size.y));
            }

            if !element._inputFeedback {
                element._inputFeedback = { 
                    hover: false
                };
                element._inputFeedbackVersion := !element._inputFeedbackVersion;
            }
            assert(element._inputFeedback);

            if element._inputFeedback.hover != hovered {
                element._inputFeedback.hover = hovered;
                element._inputFeedbackVersion := !element._inputFeedbackVersion;
            }

            for child in element.children {
                let childEvents = this.applyHitTestAndScheduleEvents(child, mousePos);
            }
        }
        else if element is hzui.TextElement {
            let pos = element.position();
            let size = element.size();

            let hovered = false;
            if pos && size {
                hovered =
                    (mousePos.x > pos.x) && (mousePos.x < (pos.x + size.x)) &&
                    (mousePos.y > pos.y) && (mousePos.y < (pos.y + size.y));
            }

            if !element._inputFeedback {
                element._inputFeedback = {
                    hover: false
                };
                element._inputFeedbackVersion := !element._inputFeedbackVersion;
            }
            assert(element._inputFeedback);

            if element._inputFeedback.hover != hovered {
                element._inputFeedback.hover = hovered;
                element._inputFeedbackVersion := !element._inputFeedbackVersion;
            }
        }
        else if element is hzui.CanvasElement {
            let pos = element.position();
            let size = element.size();

            let hovered = false;
            if pos && size {
                hovered =
                    (mousePos.x > pos.x) && (mousePos.x < (pos.x + size.x)) &&
                    (mousePos.y > pos.y) && (mousePos.y < (pos.y + size.y));
            }

            if !element._inputFeedback {
                element._inputFeedback = {
                    hover: false
                };
                element._inputFeedbackVersion := !element._inputFeedbackVersion;
            }
            assert(element._inputFeedback);

            if element._inputFeedback.hover != hovered {
                element._inputFeedback.hover = hovered;
                element._inputFeedbackVersion := !element._inputFeedbackVersion;
            }
        }

        return events;
    }

    fn process() {
        let now = time.now();
        let elapsed = now - this._prevTime;
        this._prevTime = now;

        this._framecount++;
        this._deltaTime := elapsed;
        this._timeNow := now;

        this.pmousePos = this.mousePos;
        this.mousePos = this._mousePosCb();
        this.dmousePos = {
            x: this.mousePos.x - this.pmousePos.x,
            y: this.mousePos.y - this.pmousePos.y,
        };

        // HIT TESTING PHASE
        if (this.rootComponent) {
            let prevTree = this.rootComponent.rootElement;
            let events = this.applyHitTestAndScheduleEvents(prevTree, this.mousePos);
        }

        // EVENT PHASE

        // FLUSH PHASE

        this.flushEffects();

        rx.get(this.rootTemplate);

        assert(this.rootComponent);
        return this.rootComponent.rootElement;
    }

    fn scheduleEffect(effect: () => void) {
        this.effectQueue.push(effect);
    }

    fn pushRenderContext(ctx: RenderContext) {
        this.renderStack.push(ctx);
    }

    fn popRenderContext() {
        this.renderStack.pop();
    }

    fn makeCurrentComponentAvailable(id: int) {
        let instance = null as ComponentInstance | null;

        if this.renderStack.length > 0 {
            let parent = this.renderStack[this.renderStack.length - 1].currentComponent;

            // First check if already registered in this render cycle (avoids double-creation
            // when called from both defineComponent and defineComponentImpl for the same id).
            let child = null as ComponentInstance | null;
            let alreadyRegistered = false;
            for n in parent.newChildComponents {
                if n.id == id {
                    child = n.component;
                    alreadyRegistered = true;
                }
            }

            if child is null {
                child = parent.findChild(id);
            }

            if child is null {
                child = parent.createChild(id);
            }
            assert(child);

            if !alreadyRegistered {
                parent.newChildComponents.push({
                    id: id,
                    component: child,
                });
            }

            instance = child;
        } else {
            if !this.rootComponent {
                this.rootComponent = ComponentInstance {
                    id: id,
                    rootElement: hzui.DivElement({
                        id: id,
                        style: {},
                    }),
                    propsVersion: rx.reactive<int>(0),
                };
            }
            assert(this.rootComponent);
            instance = this.rootComponent;
        }
        assert(instance);

        return instance;
    }

    fn getCurrentComponent() {
        assert(this.renderStack.length > 0);
        return this.renderStack[this.renderStack.length - 1].currentComponent;
    }

    fn getCurrentParent() {
        assert(this.renderStack.length > 0);
        return this.renderStack[this.renderStack.length - 1].currentParent;
    }

    fn destroyComponent(
        component: ComponentInstance
    ) :: final {

        for child in component.childComponents {
            this.destroyComponent(
                child.component
            );
        }

        if component.onUnmount {
            component.onUnmount();
        }

        component.elementsById = [];
        component.childComponents = [];
        component.newChildComponents = [];
    }

    fn defineComponentImpl(
        id: int,
        propsChanged: bool,
        setupFn: () => (() => void)
    ) {
        let instance = this.makeCurrentComponentAvailable(id);

        if !instance.setupDone {
            attempt {
                instance.currentTemplate = setupFn();
                instance.setupDone = true;
            } recover e {
                instance.crashed = true;
                instance.crashInfo = e;
                instance.setupDone = true;
            };
        }

        if (propsChanged) {
            instance.propsVersion++;
        }

        if instance.templateComputed is none {
            instance.templateComputed = rx.computed(() => {
                rx.get(instance.propsVersion);

                instance.newChildComponents = [];
                instance.rootElement.children = [];

                if instance.crashed && instance.crashInfo {
                    let errEl = instance.getOrCreateText(-1);
                    errEl.text := f"Component error: {instance.crashInfo.message}";
                    errEl.style := { textColor: Color(1, 0.2, 0.2, 1) };
                    instance.rootElement.children.push(errEl);
                    return none;
                }

                let stackDepthBefore = this.renderStack.length;

                this.pushRenderContext({
                    currentComponent: instance,
                    currentParent: instance.rootElement,
                });

                assert(instance.currentTemplate);
                attempt {
                    instance.currentTemplate();
                } recover e {
                    instance.crashed = true;
                    instance.crashInfo = e;
                    fmt.println(f"[crash] component {instance.id}:");
                    e.print();
                    while this.renderStack.length > stackDepthBefore {
                        this.popRenderContext();
                    }
                    let errEl = instance.getOrCreateText(-1);
                    errEl.text := f"Component error: {e.message}";
                    errEl.style := { textColor: Color(1, 0.2, 0.2, 1) };
                    instance.rootElement.children.push(errEl);
                    return none;
                };

                let oldChildren =
                    instance.childComponents;

                instance.childComponents =
                    instance.newChildComponents;

                for old in oldChildren {

                    let stillExists = false;

                    for new in instance.childComponents {
                        if new.id == old.id {
                            stillExists = true;
                            // TODO: Support "break" and use it here to optimize performance
                            // break;
                        }
                    }

                    if !stillExists {
                        this.destroyComponent(
                            old.component
                        );
                    }
                }

                this.popRenderContext();

                return none;
            });
        }

        rx.get(instance.templateComputed);

        if !instance.mounted {
            instance.mounted = true;
            if instance.onMounted {
                instance.onMounted();
            }
        }

        // attach root element into current parent if there is one
        if this.renderStack.length > 0 {
            this.renderStack[this.renderStack.length - 1].currentParent.children.push(instance.rootElement);
        }
    }

    fn defineComponent<TProps>(
        id: int,
        props: TProps,
        setupFn: (instance: InstanceData<TProps>) => (() => void)
    ) {
        let instance = this.makeCurrentComponentAvailable(id);

        // This is an object which is created once and then never created again, because component code such as
        // setup and template must capture it. Then we can continuously update the content of the object
        // such as the props with their latest state. After capturing it, component code always gets the latest
        // state of the props as long as it only captures the container and not the props themselves.
        if !instance.instanceDataForCapturing {
            instance.instanceDataForCapturing = TypeErasedBox<InstanceData<TProps>>(InstanceData<TProps> {
                _props: props,
                _propsVersion: instance.propsVersion,
            });
        }
        assert(instance.instanceDataForCapturing);
        let instanceData = instance.instanceDataForCapturing.get<InstanceData<TProps>>();
        instanceData._props = props;

        do unsafe {
            let propsChanged = true;

            if instance.prevProps {
                let prevProps = instance.prevProps.get<TProps>();
                propsChanged = props != prevProps;
            }

            if !instance.prevProps {
                instance.prevProps = TypeErasedBox<TProps>(props);
            }
            assert(instance.prevProps);
            instance.prevProps.set<TProps>(props);

            return this.defineComponentImpl(id, propsChanged, () => {
                return setupFn(instanceData);
            });
        };
    }

    fn onMounted(callback: () => none) {
        let component = this.getCurrentComponent();
        component.onMounted = callback;
    }

    fn onUnmount(callback: () => none) {
        let component = this.getCurrentComponent();
        component.onUnmount = callback;
    }

    struct WatchOptions {
        immediate?: bool;
        deep?: bool;
    }

    fn watch<T>(
        getter: () => T,
        callback: () => none,
        options: WatchOptions = {}
    ) {
        const react = rx.computed(() => {
            getter();
            callback();
            return none;
        });
        this.scheduleEffect(() => rx.get(react));

        if options.immediate {
            callback();
        }
    }

    fn queuePopFront() {
        let front = this.effectQueue[0];
        let newQueue: [](() => void) = [];
        for (let i = 1; i < this.effectQueue.length; i++) {
            newQueue.push(this.effectQueue[i]);
        }
        this.effectQueue = newQueue;
        return front;
    }

    fn flushEffects() {
        while this.effectQueue.length > 0 {
            let effect = queuePopFront();
            effect();
        }
    }

    fn div(props: DivProps, childrenFn: () => void) {
        let element = this.getCurrentComponent().getOrCreateDiv(props.id);

        if props.style is not none {
            element.style := props.style;
        }
        element.presets = props.presets;

        // attach into current parent
        this.getCurrentParent().children.push(element);

        // clear children for reconciliation
        element.children = [];

        // descend into element
        this.pushRenderContext({
            currentComponent: this.getCurrentComponent(),
            currentParent: element,
        });

        childrenFn();

        this.popRenderContext();

        if props.ref is not none {
            // TODO: This should be an identity comparison in the future.
            // Ids are not globally unique and this is not guaranteed to always work.
            // In the ideal case, we should support TypeScript-like identity comparison 
            // between objects, to compare that it is actually the same object.
            // The ID comparison is a best guess.
            if props.ref is null || props.ref.id != element.id {
                props.ref := element;
            }
        }

        return element;
    }

    fn text(props: TextProps) {
        let element = this.getCurrentComponent().getOrCreateText(props.id);

        element.text := props.text;
        if props.style is not none {
            element.style := props.style;
        }
        element.presets = props.presets;

        // attach into current parent
        this.getCurrentParent().children.push(element);

        if props.ref is not none {
            // TODO: This should be an identity comparison in the future.
            // Ids are not globally unique and this is not guaranteed to always work.
            // In the ideal case, we should support TypeScript-like identity comparison
            // between objects, to compare that it is actually the same object.
            // The ID comparison is a best guess.
            if props.ref is null || props.ref.id != element.id {
                props.ref := element;
            }
        }

        return element;
    }

    // A standalone element with an auto-managed offscreen GPU canvas.
    // `drawFn`, if given, is invoked once per frame -- not here during the
    // build phase, but later from main.hz's renderCanvas callback, which
    // runs right after layout when this frame's size is already known (so
    // there's no one-frame lag, even on the very first frame). It's cleared
    // before each such automatic redraw.
    //
    // For content that should persist across frames instead of being fully
    // redrawn every frame, draw imperatively whenever via drawToCanvas()
    // (e.g. from an event handler) instead of passing drawFn here.
    fn canvas(props: CanvasProps, drawFn?: CanvasDrawFn) {
        let element = this.getCurrentComponent().getOrCreateCanvas(props.id);

        if props.style is not none {
            element.style := props.style;
        }
        element.presets = props.presets;

        // attach into current parent
        this.getCurrentParent().children.push(element);

        if drawFn is not none {
            if !element._drawFn {
                element._drawFn = TypeErasedBox<CanvasDrawFn>(drawFn);
            } else {
                element._drawFn.set<CanvasDrawFn>(drawFn);
            }
        } else {
            element._drawFn = none;
        }

        if props.ref is not none {
            if props.ref is null || props.ref.id != element.id {
                props.ref := element;
            }
        }

        return element;
    }

    // Imperative drawing entry point: draws into the canvas element's
    // already-existing GPU canvas right now, independent of the normal
    // frame flow (e.g. usable from an event handler). No-ops if this
    // element hasn't been laid out yet (i.e. never rendered a frame), since
    // there's no canvas to draw into yet. `clear` defaults to false so
    // repeated calls accumulate instead of erasing prior content.
    fn drawToCanvas(element: mut hzui.CanvasElement, drawFn: CanvasDrawFn, clear: bool = false) {
        if !element._handle {
            return;
        }
        let handle = element._handle.get<CanvasHandle>();
        let r = gfx.Renderer(handle.canvas);
        drawFn(r);
        r.commit(clear);
    }

    fn ref<T>(): ElementRef<T> {
        return rx.shallowReactive<T | null>(null);
    }
}

type ElementRef<T> = rx.ShallowReactive<T | null>;

struct HeaderArgs {
    id: int;
    title: str;

    fn operator!=(other: HeaderArgs) {
        return this.id != other.id || this.title != other.title;
    }
}
fn Header(ui: UIContext, args: HeaderArgs) {
    ui.defineComponent(args.id, args, (instance: InstanceData<HeaderArgs>) => {
        return (): void => {
            ui.div({
                id: 1,
                style: {
                    cornerRadius: hzui.StyleCornerRadiusSimple { value: 10.0 },
                },
                presets: [
                    presets.bg(Color(0.9, 0.2, 0.2, 1)),
                    presets.p(4),
                    presets.align(hzui.Align.Center),
                ]
            }, (): void => {
                ui.text({ id: 2, text: instance.props().title, style: { fontSize: 42.0 } });
            });
        };
    });
}

struct NavItemArgs {
    id: int;
    label: str;

    fn operator!=(other: NavItemArgs) {
        return this.id != other.id || this.label != other.label;
    }
}

fn NavItem(ui: UIContext, args: NavItemArgs) {
    ui.defineComponent(args.id, args, (instance: InstanceData<NavItemArgs>) => {

        let divRef = ui.ref<hzui.DivElement>();

        let hover = rx.computed(() => {
            let element = rx.get(divRef);
            if !element {
                return false;
            }
            if (element.hover()) {
                let a: []str = [];
                a.pop();
            }
            return element.hover();
        });

        return (): void => {
            ui.div({
                id: 1,
                ref: divRef,
                style: {
                    backgroundColor: hover ? Color(1, 0, 0, 1) : Color(0.15, 0.45, 0.75, 1),
                    padding: hzui.StylePaddingFull { left: 15.0, right: 15.0, top: 8.0, bottom: 8.0 },
                    cornerRadius: hzui.StyleCornerRadiusSimple { value: 6.0 },
                }
            }, (): void => {
                ui.text({ id: 2, text: instance.props().label });
            });
        };
    });
}

struct SidebarArgs {
    id: int;

    fn operator!=(other: SidebarArgs) {
        return this.id != other.id;
    }
}

fn Sidebar(ui: UIContext, args: SidebarArgs) {
    ui.defineComponent(args.id, args, (instance: InstanceData<SidebarArgs>) => {

        return (): void => {
            ui.div({
                id: 1,
                style: {
                    backgroundColor: Color(0.2, 0.6, 0.9, 1),
                    padding: hzui.StylePaddingSimple { value: 20.0 },
                    direction: hzui.Direction.Column,
                    gap: 8.0,
                    width: 180.0,
                }
            }, (): void => {
                ui.text({ id: 2, text: "Menu" });
                NavItem(ui, { id: 10, label: "Dashboard" });
                NavItem(ui, { id: 20, label: "Settings" });
                NavItem(ui, { id: 30, label: "About" });
            });
        };
    });
}

struct ContentAreaArgs {
    id: int;
    text: str;

    fn operator!=(other: ContentAreaArgs) {
        return this.id != other.id || this.text != other.text;
    }
}

fn ContentArea(ui: UIContext, args: ContentAreaArgs) {
    ui.defineComponent(args.id, args, (instance: InstanceData<ContentAreaArgs>) => {

        let divRef = ui.ref<hzui.DivElement>();
        let h = rx.computed(() => {
            if let ref = rx.get(divRef) {
                return ref.hover();
            }
            return false;
        })

        return (): void => {
            ui.div({
                id: 100,
                ref: divRef,
                style: {
                    direction: hzui.Direction.Column,
                    align: hzui.Align.Center,
                },
                presets: [
                    presets.p(2),
                    presets.bg("#33CC66FF"),
                    presets.gap(4),
                ],
            }, (): void => {
                fmt.println("Rerender content area");
                ui.text({ id: 200, text: "Welcome to the content area!", style: { fontSize: 24.0 } });
                ui.text({ id: 300, text: "This is rendered via the component system." });
                ui.text({ id: 400, text: "Flexbox layout powered by Clay." });
                ui.text({ id: 500, text: instance.props().text });

                ui.canvas({
                    id: 600,
                    style: { width: 200.0, height: 150.0 },
                }, (r: mut gfx.Renderer): void => {
                    r.drawRect({ pos: Vec2(10, 10), size: Vec2(80, 60), fillColor: Color(1, 0, 0, 1) });
                    r.drawRect({ pos: Vec2(100, 70), size: Vec2(60, 50), fillColor: Color(0, 0, 1, 1) });
                });
            });
        };
    });
}

struct InfoBoxArgs {
    id: int;

    fn operator!=(other: InfoBoxArgs) {
        return this.id != other.id;
    }
}
namespace tsk {

struct Point {
    x: real;
    y: real;
    pressure: real;
}

struct Shape {
    variant: str;
    points: []Point;
    penThickness: real;
    penColor: str;
}

struct Page {
    shapes: []Shape;
}

struct FileData {
    pageColor: str;
    gridColor: str;
    gridType: str;
    pages: []Page;
}

struct File {
    filetype: str;
    fileVersion: int;
    data: FileData;
}

}

fn InfoBox(ui: UIContext, args: InfoBoxArgs) {
    ui.defineComponent(args.id, args, (instance: InstanceData<InfoBoxArgs>) => {

        let tesselatedShapes: []tesselate.TesselationResult = [];

        // Load TSK Shapes
        let testTsk = fs.readText("Test.tsk");
        if !testTsk {
            fmt.println("File loading failed");
        }
        else {
            let s2 = time.now();
            let result = json.structuredParse<tsk.File>(testTsk);
            fmt.println(f"Parsed structured json in {time.now() - s2} seconds");

            // Tessellate outlines once before the loop
            let start = time.now();

            if result {
                let page = result.data.pages[0];

                let accuracyScaling = 10.0;
                let tess = tesselate.Tesselator();
                for (let s = 0; s < page.shapes.length; s++) {
                    let shape = page.shapes[s];

                    // Perfect Freehand
                    let pf = perfect_freehand.PerfectFreehand({
                        size: shape.penThickness * accuracyScaling,
                        thinning: 0.1,
                        smoothing: 0.0,
                        streamline: 0.6,
                        simulatePressure: false,
                        last: true,
                    });

                    for point in shape.points {
                        pf.addPoint({
                            x: point.x * accuracyScaling,
                            y: point.y * accuracyScaling,
                        });
                    }

                    let points: []Vec2 = [];
                    if let outline = pf.compute() {
                        points = outline;
                    }

                    pf.destroy();

                    // Now tesselate
                    if points.length > 0 {
                        tess.beginPath();
                        tess.moveTo(Vec2(points[0].x / accuracyScaling, points[0].y / accuracyScaling));
                        for (let p = 1; p < points.length; p++) {
                            tess.lineTo(Vec2(points[p].x / accuracyScaling, points[p].y / accuracyScaling));
                        }
                        tess.closePath();
                        if let result = tess.tessellate(0.25) { tesselatedShapes.push(result); }
                    }
                }
                tess.destroy();
                fmt.println(f"Tessellated {tesselatedShapes.length} shapes");
            }
            else {
                fmt.println("Failed parsing: ", result);
            }

            for (let s = 0; s < tesselatedShapes.length; s++) {
                let shape = tesselatedShapes[s];

                for (let i = 0; i < shape.vertices.length; i++) {
                    shape.vertices[i].x = (shape.vertices[i].x - 100.0) * 20.0;
                    shape.vertices[i].y = (shape.vertices[i].y - 200.0) * 20.0;
                }
            }

            let end = time.now();
            fmt.println(f"Tesselated shapes in {(end - start) * 1000.0} ms");
        }

        return (): void => {
            ui.canvas({
                id: 1000,
                style: { width: 500.0 },
            }, (r: mut gfx.Renderer): void => {
                // r.drawRect({ pos: Vec2(0, 0), size: Vec2(1000, 1000), fillColor: Color(1, 0, 0, 1) });
                // r.drawRect({ pos: Vec2(10, 10), size: Vec2(80, 60), fillColor: Color(1, 0, 0, 1) });
                // r.drawRect({ pos: Vec2(100, 70), size: Vec2(60, 50), fillColor: Color(0, 0, 1, 1) });

                // Render tessellated shapes
                for (let s = 0; s < tesselatedShapes.length; s++) {
                    let shape = tesselatedShapes[s];

                    for (let i = 0; i < shape.vertices.length; i++) {
                        if (true) {
                            shape.vertices[i].x = shape.vertices[i].x + ui.dmousePos.x;
                            shape.vertices[i].y = shape.vertices[i].y + ui.dmousePos.y;
                        }
                    }

                    r.addTriangles(shape.vertices, shape.indices, "#000");
                }

                let center = Vec2(200, 200);
                let alpha = ui.now() * 20.0;
                let radius = 40.0;
                r.drawRect({
                    pos: Vec2(center.x + math.cos(alpha) * radius, center.y + math.sin(alpha) * radius), 
                    size: Vec2(50, 50),
                    fillColor: "#F00",
                });
            });
        };
    });
}

struct FooterArgs {
    id: int;

    fn operator!=(other: FooterArgs) {
        return this.id != other.id;
    }
}

fn Footer(ui: UIContext, args: FooterArgs) {
    ui.defineComponent(args.id, args, (instance: InstanceData<FooterArgs>) => {

        let text = rx.reactive<str>("This is some actual text to read");

        return (): void => {
            ui.div({
                id: 10000,
                presets: [
                    presets.bg("#181818"),
                    presets.textColor("#F00"),
                    presets.p(15),
                    presets.align(hzui.Align.Center),
                ],
            }, (): void => {
                ui.text({ id: 20000, text: text, style: { fontSize: 12.0 } });
            });
        };
    });
}

