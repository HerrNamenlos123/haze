struct RootArgs {
    fn operator!=(other: RootArgs) {
        return false;
    }
}

fn UI(ui: UIContext) {
    ui.defineComponent(0, RootArgs {}, () =>
        ui.div({
            id: 1,
            style: {
                backgroundColor: Color(0.15, 0.15, 0.15, 1),
                padding: hzui.StylePaddingSimple { value: 30.0 },
                direction: hzui.Direction.Column,
                fontFamily: "roboto",
                fontSize: 16.0,
                textColor: Color(1, 1, 1, 1),
                gap: 10.0,
            }
        }, () => {
            fmt.println("Root rerender");
            // Header(ui, { id: 1, title: f"HAZE UI — Component System (Frame #{5})" });
            Header(ui, { id: 1, title: f"HAZE UI — Component System (Frame #{ui.framecount()})" });

            let text = rx.computed(() => {
                return f"This text is running since {ui.now() as int} seconds.";
            });

            ui.div({
                id: 2,
                style: {
                    direction: hzui.Direction.Row,
                    padding: hzui.StylePaddingSimple { value: 20.0 },
                    backgroundColor: Color(0.25, 0.25, 0.25, 1),
                    justify: hzui.Justify.SpaceBetween,
                    cornerRadius: hzui.StyleCornerRadiusSimple { value: 20.0 },
                    gap: 30.0,
                }
            }, () => {
                Sidebar(ui, { id: 2 });
                ContentArea(ui, { id: 3, text: text });
                InfoBox(ui, { id: 4 });
            });

            Footer(ui, { id: 5 });
        })
    );
}
