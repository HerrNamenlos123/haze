fn UI() {
    defineComponent({ id: 0 }, () =>
        div({
            id: 3,
            style: {
                backgroundColor: Color(0.15, 0.15, 0.15, 1),
                padding: ui.StylePaddingSimple { value: 30.0 },
                direction: ui.Direction.Column,
                fontFamily: "roboto",
                fontSize: 16.0,
                textColor: Color(1, 1, 1, 1),
                gap: 10.0,
            }
        }, () => {
            Header({ id: 10, title: "HAZE UI — Component System" });

            div({
                id: 4,
                style: {
                    direction: ui.Direction.Row,
                    padding: ui.StylePaddingSimple { value: 20.0 },
                    backgroundColor: Color(0.25, 0.25, 0.25, 1),
                    justify: ui.Justify.SpaceBetween,
                    cornerRadius: ui.StyleCornerRadiusSimple { value: 20.0 },
                    gap: 30.0,
                }
            }, () => {
                Sidebar({ id: 20 });
                ContentArea({ id: 30 });
                InfoBox({ id: 40 });
            });

            Footer({ id: 50 });
        })
    );
}

fn computeUI() {
    let ctx = getGlobalContext();
    if !ctx.rootTemplate {
        ctx.rootTemplate = rx.computed<none>(() => {
            UI();
        });
    }
    assert(ctx.rootTemplate);

    if !ctx.framecount {
        ctx.framecount = rx.reactive<int>(0);
    }
    assert(ctx.framecount);

    ctx.generation++;
    ctx.framecount++;

    flushEffects();

    rx.get(ctx.rootTemplate);

    let root = getOrCreateComponent(0);
    printTree(root.rootElement);
    return root.rootElement;
}
