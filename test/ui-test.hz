
struct GlobalContext {
    renderStack: []RenderContext = [];
    generation: int = 0;
    effectQueue: [](() => void) = [];
    componentCache: []inline ComponentCache = [];
    rootTemplate: rx.Computed<none> | null = null;
    framecount: rx.Reactive<int> | null = null;
}

let g_globalContext: GlobalContext | null = null;

fn getGlobalContext(): GlobalContext :: final {
    if !g_globalContext {
        g_globalContext = GlobalContext {};
    }
    assert(g_globalContext);
    return g_globalContext;
}

fn currentContext(): RenderContext {
    return getGlobalContext().renderStack[getGlobalContext().renderStack.length - 1];
}

fn scheduleEffect(effect: () => void) {
    getGlobalContext().effectQueue.push(effect);
}

fn pushRenderContext(ctx: RenderContext) {
    getGlobalContext().renderStack.push(ctx);
}

fn popRenderContext() {
    getGlobalContext().renderStack.pop();
}

struct ComponentCache {
    id: int;
    component: ComponentInstance;
}

fn getOrCreateComponent(id: int): ComponentInstance {
    for n in getGlobalContext().componentCache {
        if n.id == id {
            return n.component;
        }
    }
    let newComponent = ComponentInstance {
        id: id,
        rootElement: ui.DivElement {
            id: 0,
            style: {},
        },
    };
    getGlobalContext().componentCache.push({
        id: id,
        component: newComponent,
    });
    return newComponent;
}

struct ElementCache {
    id: int;
    element: mut ui.Element;
}

struct A {}
struct B {}
type C = A | B;

struct ComponentInstance {
    id: int;

    templateComputed?: rx.Computed<none>;

    elementsById: []inline ElementCache = [];

    rootElement: ui.DivElement;

    fn getOrCreateDiv(id: int): mut ui.DivElement {
        for n in this.elementsById {
            if n.id == id {
                assert(n.element is mut ui.DivElement, "Div expected but other node type encountered");
                return n.element;
            }
        }
        let newElement = ui.DivElement { id: id, style: {} };
        this.elementsById.push({ id: id, element: newElement });
        return newElement;
    }

    fn getOrCreateText(id: int): mut ui.TextElement {
        for n in this.elementsById {
            if n.id == id {
                assert(n.element is mut ui.TextElement, "Text element expected but other node type encountered");
                return n.element;
            }
        }
        let newElement = ui.TextElement { id: id, text: "", style: {} };
        this.elementsById.push({ id: id, element: newElement });
        return newElement;
    }
}

struct RenderContext {
    currentComponent: ComponentInstance;
    currentParent: ui.DivElement;
}

struct DivProps {
    id: int;
    style?: ui.DivStyle;
}

struct TextProps {
    id: int;
    style?: ui.TextStyle;
    text: str;
}

struct ComponentProps {
    id: int;
}

fn div(props: DivProps, childrenFn: () => none) {
    let ctx = currentContext();
    let element = ctx.currentComponent.getOrCreateDiv(props.id);

    if props.style is not none {
        element.style = props.style;
    }

    // attach into current parent
    ctx.currentParent.children.push(element);

    // clear children for reconciliation
    element.children = [];

    // descend into element
    pushRenderContext({
        currentComponent: ctx.currentComponent,
        currentParent: element,
    });

    childrenFn();

    popRenderContext();
}

fn text(props: TextProps) {
    let ctx = currentContext();
    let element = ctx.currentComponent.getOrCreateText(props.id);

    element.text = props.text;
    if props.style is not none {
        element.style = props.style;
    }

    // attach into current parent
    ctx.currentParent.children.push(element);
}

fn defineComponent(
    props: ComponentProps,
    template: () => none
) {
    let instance = getOrCreateComponent(props.id);

    if instance.templateComputed is none {
        instance.templateComputed = rx.computed(() => {
            instance.rootElement.children = [];

            pushRenderContext({
                currentComponent: instance,
                currentParent: instance.rootElement,
            });

            template();

            popRenderContext();

            return none;
        });
    }

    rx.get(instance.templateComputed);

    // attach root element into current parent if there is one
    let stack = getGlobalContext().renderStack;
    if stack.length > 0 {
        currentContext().currentParent.children.push(instance.rootElement);
    }
}

fn printTree(element: ui.Element, depth: int = 0): void :: final {
    let indent = "";
    for (let i = 0; i < depth; i++) {
        indent = indent + "  ";
    }

    if element is ui.DivElement {
        fmt.println(f"{indent}Div({element.id})");
        for child in element.children {
            printTree(child, depth + 1);
        }
    }
    else if element is ui.TextElement {
        fmt.println(f"{indent}Text({element.id}): {element.text}");
    }
}

struct ButtonArgs {
    id: int;
    label: str;
    color: Color;
}

struct WatchOptions {
    immediate?: bool;
    deep?: bool;
}

fn watch<T>(
    getter: () => T,
    callback: () => none,
    options: WatchOptions = {}
) {
    const react = rx.computed(() => {
        getter();
        callback();
        return none;
    });
    scheduleEffect(() => rx.get(react));

    if options.immediate {
        callback();
    }
}

fn queuePopFront() {
    let front = getGlobalContext().effectQueue[0];
    let newQueue: [](() => void) = [];
    for (let i = 1; i < getGlobalContext().effectQueue.length; i++) {
        newQueue.push(getGlobalContext().effectQueue[i]);
    }
    getGlobalContext().effectQueue = newQueue;
    return front;
}

fn flushEffects() {
    while getGlobalContext().effectQueue.length > 0 {
        let effect = queuePopFront();
        effect();
    }
}

fn hover(): bool {
    return true;
}

fn Button(args: ButtonArgs) {

    let buttonLabel = rx.computed(() => {
        let frame = getGlobalContext().framecount;
        assert(frame);
        return f"args.label #{frame}";
    })

    defineComponent({ id: args.id }, () =>
        div({
            id: 1,
            style: {
                textColor: hover() ? Color("#0000FF") : Color(args.color),
            }
        }, () => {
            text({ id: 2, text: buttonLabel });
        })
    );
}

fn UI() {
    let label = rx.reactive<str>("My Button");
    let color = rx.shallowReactive<Color>(Color("#FF0000"));

    defineComponent({ id: 0 }, () =>
        div({
            id: 3
        }, () => {
            Button({
                id: 20,
                label: label,
                color: color,
            });
        })
    );
}

fn computeUI() {
    let ctx = getGlobalContext();
    if !ctx.rootTemplate {
        ctx.rootTemplate = rx.computed<none>(() => {
            UI();
        });
    }
    assert(ctx.rootTemplate);

    if !ctx.framecount {
        ctx.framecount = rx.reactive<int>(0);
    }
    assert(ctx.framecount);

    ctx.generation++;
    ctx.framecount++;

    flushEffects();

    rx.get(ctx.rootTemplate);

    let root = getOrCreateComponent(0);
    printTree(root.rootElement);
    return root.rootElement;
}
