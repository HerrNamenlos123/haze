
let g_renderStack: []RenderContext = [];
let g_generation: int = 0;
let g_effectQueue: [](() => void) = [];

fn currentContext(): RenderContext {
    return g_renderStack[g_renderStack.length - 1];
}

fn scheduleEffect(effect: () => void) {
    g_effectQueue.push(effect);
}

fn pushRenderContext(ctx: RenderContext) {
    g_renderStack.push(ctx);
}

fn popRenderContext() {
    g_renderStack.pop();
}

let g_componentCache: []inline ComponentCache = [];

struct ComponentCache {
    id: int;
    component: ComponentInstance;
}

fn getOrCreateComponent(id: int): ComponentInstance {
    for n in g_componentCache {
        if n.id == id {
            return n.component;
        }
    }
    let newComponent = ComponentInstance {
        id: id,
    };
    g_componentCache.push({
        id: id,
        component: newComponent,
    });
    return newComponent;
}

enum NodeType {
    Div,
    Text,
}

struct Node {
    id: int;
    type: NodeType;
    generation: int;

    parent?: Node;

    children: []Node = [];
    newChildren: []Node = [];
    text?: str;

    // layout: LayoutRect;

    style: ui.DivStyle | ui.TextStyle;
}

struct DivProps {
    id: int;
    style?: ui.DivStyle;
}

struct TextProps {
    id: int;
    style?: ui.TextStyle;
    text: str;
}

struct ComponentProps {
    id: int;
}

struct NodeCache {
    id: int;
    node: mut Node;
}

struct ComponentInstance {
    id: int;

    // refs
    // watchers
    // computeds
    templateComputed?: rx.Computed<none>;
    dirty: bool = true;

    // nodesById: Map<u64, Node>;
    nodesById: []inline NodeCache = [];

    rootNode: Node = {
        id: -1,
        type: NodeType.Div,
        generation: g_generation,
        style: ui.DivStyle {},
    };

    fn getNode(id: int) {
        for n in this.nodesById {
            if n.id == id {
                return n.node;
            }
        }
        let newNode = Node {
            id: id,
            type: NodeType.Div,
            generation: g_generation,
            style: ui.DivStyle {},
        };
        this.nodesById.push({
            id: id,
            node: newNode,
        });
        return newNode;
    }
}

struct RenderContext {
    currentComponent: ComponentInstance;
    currentParent: Node;
}

fn div(props: DivProps, childrenFn: () => none) {

    let ctx = currentContext();

    // reconcile persistent node
    let node = ctx.currentComponent.getNode(props.id);

    node.id = props.id;
    node.type = NodeType.Div;

    if props.style is not none {
        node.style = props.style;
    }

    // parent relationship
    node.parent = ctx.currentParent;

    // attach into current parent
    ctx.currentParent.newChildren.push(node);

    // reconciliation preparation
    // node.newChildren.clear();
    node.newChildren = [];
    node.generation = g_generation;

    // descend into node
    pushRenderContext({
        currentComponent: ctx.currentComponent,
        currentParent: node,
    });

    // build children
    childrenFn();

    // finalize reconciliation
    node.children = node.newChildren;

    // leave node
    popRenderContext();
}

fn text(props: TextProps) {

    let ctx = currentContext();

    // reconcile persistent node
    let node = ctx.currentComponent.getNode(props.id);

    node.id = props.id;
    node.type = NodeType.Text;

    if props.style is not none {
        node.style = props.style;
    }

    node.text = props.text;
    node.generation = g_generation;

    // parent relationship
    node.parent = ctx.currentParent;

    // attach into current parent
    ctx.currentParent.newChildren.push(node);
}

fn defineComponent(
    props: ComponentProps,
    template: () => none
) {
    let instance = getOrCreateComponent(props.id);

    // prepare reconciliation
    // instance.rootNode.newChildren.clear();
    instance.rootNode.newChildren = [];

    // enter component render scope
    pushRenderContext({
        currentComponent: instance,
        currentParent: instance.rootNode,
    });

    // execute template
    if instance.templateComputed is none {
        instance.templateComputed = rx.computed(() => {

            // instance.rootNode.newChildren.clear();
            instance.rootNode.newChildren = [];

            pushRenderContext({
                currentComponent: instance,
                currentParent: instance.rootNode,
            });

            template();

            instance.rootNode.children =
                instance.rootNode.newChildren;

            popRenderContext();

            return none;
        });
    }
    
    rx.get(instance.templateComputed);

    // finalize reconciliation
    instance.rootNode.children =
        instance.rootNode.newChildren;

    // leave component render scope
    popRenderContext();
}

fn printTree(node: Node, depth: int = 0): void :: final {

    let indent = "";
    for (let i = 0; i < depth; i++) {
        indent = indent + "  ";
    }

    if node.type == NodeType.Div {
        fmt.println(f"{indent}Div({node.id})");
    }

    if node.type == NodeType.Text {
        if node.text {
            fmt.println(f"{indent}Text({node.id}): {node.text}");
        }
        else {
            fmt.println(f"{indent}Text({node.id}): {node.text}");
        }
    }

    for child in node.children {
        printTree(child, depth + 1);
    }
}

struct ButtonArgs {
    id: int;
    label: str;
    color: Color;
}

struct WatchOptions {
    immediate?: bool;
    deep?: bool;
}

let g_watchers: []rx.Computed<none> = [];

fn watch<T>(
    getter: () => T,
    callback: () => none,
    options: WatchOptions = {}
) {
    const react = rx.computed(() => {
        getter();
        callback();
        return none;
    });
    g_watchers.push(react);

    if options.immediate {
        callback();
    }
}

fn queuePopFront() {
    let front = g_effectQueue[0];
    let newQueue: [](() => void) = [];
    for (let i = 1; i < g_effectQueue.length; i++) {
        newQueue.push(g_effectQueue[1]);
    }
    g_effectQueue = newQueue;
    return front;
}

fn flushEffects() {
    while g_effectQueue.length > 0 {
        let effect = queuePopFront();
        effect();
    }
}

let g_framecount = rx.reactive<int>(0);
fn hover(): bool {
    return true;
}

fn Button(args: ButtonArgs) {

    let buttonLabel = rx.computed(() => {
        return f"args.label #{g_framecount}";
    })

    defineComponent({ id: args.id }, () => 
        div({
            id: 1,
            style: {
                textColor: hover() ? Color("#0000FF") : Color(args.color),
            }
        }, () => {
            text({ id: 2, text: buttonLabel });
        })
    );
}

fn UI() {
    let label = rx.reactive<str>("My Button");
    let color = rx.shallowReactive<Color>(Color("#FF0000"));

    defineComponent({ id: 0 }, () => 
        div({
            id: 3
        }, () => {
            Button({
                id: 20,
                label: label,
                color: color,
            });
        })
    );
}

fn cleanupNodes() {
    // TODO: Remove nodes with an old generation from the array
    // but currently splicing arrays is not supported yet
}

let g_rootTemplate = rx.computed(() => {
    UI();
});

fn computeUI() {
    g_generation += 1;
    g_framecount++;

    rx.get(g_rootTemplate);

    let root = getOrCreateComponent(0);
    printTree(root.rootNode);
}