
struct GlobalContext {
    renderStack: []RenderContext = [];
    generation: int = 0;
    effectQueue: [](() => void) = [];
    componentCache: []inline ComponentCache = [];
    rootTemplate: rx.Computed<none> | null = null;
    framecount: rx.Reactive<int> | null = null;
}

let g_globalContext: GlobalContext | null = null;

fn getGlobalContext(): GlobalContext :: final {
    if !g_globalContext {
        g_globalContext = GlobalContext {};
    }
    assert(g_globalContext);
    return g_globalContext;
}

fn currentContext(): RenderContext {
    return getGlobalContext().renderStack[getGlobalContext().renderStack.length - 1];
}

fn scheduleEffect(effect: () => void) {
    getGlobalContext().effectQueue.push(effect);
}

fn pushRenderContext(ctx: RenderContext) {
    getGlobalContext().renderStack.push(ctx);
}

fn popRenderContext() {
    getGlobalContext().renderStack.pop();
}

struct ComponentCache {
    id: int;
    component: ComponentInstance;
}

fn getOrCreateComponent(id: int): ComponentInstance {
    for n in getGlobalContext().componentCache {
        if n.id == id {
            return n.component;
        }
    }
    let newComponent = ComponentInstance {
        id: id,
        rootNode: {
            id: -1,
            type: NodeType.Div,
            generation: getGlobalContext().generation,
            style: ui.DivStyle {},
        }
    };
    getGlobalContext().componentCache.push({
        id: id,
        component: newComponent,
    });
    return newComponent;
}

enum NodeType {
    Div,
    Text,
}

struct Node {
    id: int;
    type: NodeType;
    generation: int;

    parent?: Node;

    children: []Node = [];
    newChildren: []Node = [];
    text?: str;

    // layout: LayoutRect;

    style: ui.DivStyle | ui.TextStyle;
}

struct DivProps {
    id: int;
    style?: ui.DivStyle;
}

struct TextProps {
    id: int;
    style?: ui.TextStyle;
    text: str;
}

struct ComponentProps {
    id: int;
}

struct NodeCache {
    id: int;
    node: mut Node;
}

struct ComponentInstance {
    id: int;

    // refs
    // watchers
    // computeds
    templateComputed?: rx.Computed<none>;
    dirty: bool = true;

    // nodesById: Map<u64, Node>;
    nodesById: []inline NodeCache = [];

    rootNode: Node;

    fn getNode(id: int) {
        for n in this.nodesById {
            if n.id == id {
                return n.node;
            }
        }
        let newNode = Node {
            id: id,
            type: NodeType.Div,
            generation: getGlobalContext().generation,
            style: ui.DivStyle {},
        };
        this.nodesById.push({
            id: id,
            node: newNode,
        });
        return newNode;
    }
}

struct RenderContext {
    currentComponent: ComponentInstance;
    currentParent: Node;
}

fn div(props: DivProps, childrenFn: () => none) {

    let ctx = currentContext();

    // reconcile persistent node
    let node = ctx.currentComponent.getNode(props.id);

    node.id = props.id;
    node.type = NodeType.Div;

    if props.style is not none {
        node.style = props.style;
    }

    // parent relationship
    node.parent = ctx.currentParent;

    // attach into current parent
    ctx.currentParent.newChildren.push(node);

    // reconciliation preparation
    // node.newChildren.clear();
    node.newChildren = [];
    node.generation = getGlobalContext().generation;

    // descend into node
    pushRenderContext({
        currentComponent: ctx.currentComponent,
        currentParent: node,
    });

    // build children
    childrenFn();

    // finalize reconciliation
    node.children = node.newChildren;

    // leave node
    popRenderContext();
}

fn text(props: TextProps) {

    let ctx = currentContext();

    // reconcile persistent node
    let node = ctx.currentComponent.getNode(props.id);

    node.id = props.id;
    node.type = NodeType.Text;

    if props.style is not none {
        node.style = props.style;
    }

    node.text = props.text;
    node.generation = getGlobalContext().generation;

    // parent relationship
    node.parent = ctx.currentParent;

    // attach into current parent
    ctx.currentParent.newChildren.push(node);
}

fn defineComponent(
    props: ComponentProps,
    template: () => none
) {
    let instance = getOrCreateComponent(props.id);

    // prepare reconciliation
    // instance.rootNode.newChildren.clear();
    instance.rootNode.newChildren = [];

    // enter component render scope
    pushRenderContext({
        currentComponent: instance,
        currentParent: instance.rootNode,
    });

    // execute template
    if instance.templateComputed is none {
        instance.templateComputed = rx.computed(() => {

            // instance.rootNode.newChildren.clear();
            instance.rootNode.newChildren = [];

            pushRenderContext({
                currentComponent: instance,
                currentParent: instance.rootNode,
            });

            template();

            instance.rootNode.children =
                instance.rootNode.newChildren;

            popRenderContext();

            return none;
        });
    }
    
    rx.get(instance.templateComputed);

    // finalize reconciliation
    instance.rootNode.children =
        instance.rootNode.newChildren;

    // leave component render scope
    popRenderContext();
}

fn printTree(node: Node, depth: int = 0): void :: final {

    let indent = "";
    for (let i = 0; i < depth; i++) {
        indent = indent + "  ";
    }

    if node.type == NodeType.Div {
        fmt.println(f"{indent}Div({node.id})");
    }

    if node.type == NodeType.Text {
        if node.text {
            fmt.println(f"{indent}Text({node.id}): {node.text}");
        }
        else {
            fmt.println(f"{indent}Text({node.id}): {node.text}");
        }
    }

    for child in node.children {
        printTree(child, depth + 1);
    }
}

struct ButtonArgs {
    id: int;
    label: str;
    color: Color;
}

struct WatchOptions {
    immediate?: bool;
    deep?: bool;
}

fn watch<T>(
    getter: () => T,
    callback: () => none,
    options: WatchOptions = {}
) {
    const react = rx.computed(() => {
        getter();
        callback();
        return none;
    });
    scheduleEffect(() => rx.get(react));

    if options.immediate {
        callback();
    }
}

fn queuePopFront() {
    let front = getGlobalContext().effectQueue[0];
    let newQueue: [](() => void) = [];
    for (let i = 1; i < getGlobalContext().effectQueue.length; i++) {
        newQueue.push(getGlobalContext().effectQueue[i]);
    }
    getGlobalContext().effectQueue = newQueue;
    return front;
}

fn flushEffects() {
    while getGlobalContext().effectQueue.length > 0 {
        let effect = queuePopFront();
        effect();
    }
}

fn hover(): bool {
    return true;
}

fn Button(args: ButtonArgs) {

    let buttonLabel = rx.computed(() => {
        let frame = getGlobalContext().framecount;
        assert(frame);
        return f"args.label #{frame}";
    })

    defineComponent({ id: args.id }, () => 
        div({
            id: 1,
            style: {
                textColor: hover() ? Color("#0000FF") : Color(args.color),
            }
        }, () => {
            text({ id: 2, text: buttonLabel });
        })
    );
}

fn UI() {
    let label = rx.reactive<str>("My Button");
    let color = rx.shallowReactive<Color>(Color("#FF0000"));

    defineComponent({ id: 0 }, () => 
        div({
            id: 3
        }, () => {
            Button({
                id: 20,
                label: label,
                color: color,
            });
        })
    );
}

