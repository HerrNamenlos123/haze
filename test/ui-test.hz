    id: int;

    fn operator!=(other: FooterArgs) {
        return this.id != other.id;
    }
}

fn Footer(ui: UIContext, args: FooterArgs) {
    ui.defineComponent(args.id, args, () =>
        ui.div({
            id: 1,
            style: {
                backgroundColor: Color(0.4, 0.4, 0.9, 1),
                padding: hzui.StylePaddingSimple { value: 15.0 },
                align: hzui.Align.Center,
            }
