import fontstash;

inline struct Vertex {
    pos: Vec3f = {};
    color: Colorf = {};
}

inline struct Globals {
    screenSize: inline Vec2f;
}

max<T>(a: T, b: T): T => {
    if a >= b {
        return a;
    }
    return b;
}

min<T>(a: T, b: T): T => {
    if a <= b {
        return a;
    }
    return b;
}

inline struct PrimitiveInstance {
    pos: Vec2f;            // center position in pixels
    size: Vec2f;           // width/height
    radiusTopLeft: f32;           // corner radius for rounded rect
    radiusTopRight: f32;           // corner radius for rounded rect
    radiusBottomLeft: f32;           // corner radius for rounded rect
    radiusBottomRight: f32;           // corner radius for rounded rect
    borderThickness: f32;  // 0 = no border
    fillColor: Colorf;
    borderColor: Colorf;
    type: u32;             // 0 = Filled Rounded Rectangle, 1 = Outlined Rounded Rectangle

    // For glyph rendering:
    uvMin: Vec2f;
    uvMax: Vec2f;
};

inline struct QuadVertex {
    pos: Vec2f;  // [-0.5, -0.5] .. [0.5, 0.5]
};

inline struct RendererOptions {
    size: Vec2i;
    device: mut wgpu.Device;
    surface: mut wgpu.Surface;
    surfaceFormats: []wgpu.TextureFormat;
    shadercode: rx.Reactive<str>;
}

struct TextRenderer {
    fs: fontstash.FontStash;
    glyphBuffer: []fontstash.Glyph;
    atlasUploaded: bool = false;

    constructor() {
        let glyphBuffer: []fontstash.Glyph = [];
        glyphBuffer.reserve(1024);

        return TextRenderer {
            fs: fontstash.FontStash(1024, 1024),
            glyphBuffer: glyphBuffer,
        };
    }

    drawText(
        renderer: Renderer,
        font: int,
        size: f32,
        x: f32,
        y: f32,
        text: str,
        color: Color
    ) {
        // TODO: Add ability to reset/clear an array in-place instead of replacing it, for better memory efficiency
        this.glyphBuffer = [];

        this.fs.layoutText(
            font,
            size,
            x,
            y,
            text,
            this.glyphBuffer
        );

        for glyph in this.glyphBuffer {
            let w: real = glyph.x1 - glyph.x0;
            let h: real = glyph.y1 - glyph.y0;

            renderer.primitives.push({
                type: 2,

                pos: {
                    x: (glyph.x0 as real + w / 2.0) as f32,
                    y: (glyph.y0 as real + h / 2.0) as f32
                },

                size: { x: w as f32, y: h as f32 },

                radiusTopLeft: 0,
                radiusTopRight: 0,
                radiusBottomLeft: 0,
                radiusBottomRight: 0,

                borderThickness: 0,

                fillColor: {
                    r: color.r as f32,
                    g: color.g as f32,
                    b: color.b as f32,
                    a: color.a as f32,
                },

                borderColor: { r: 0, g: 0, b: 0, a: 0 },

                uvMin: { x: glyph.s0, y: glyph.t0 },
                uvMax: { x: glyph.s1, y: glyph.t1 }
            });
        }
    }
}

opaque struct Renderer {
    windowSize: Vec2i;
    queue: mut wgpu.Queue;
    device: mut wgpu.Device;
    surface: mut wgpu.Surface;
    pipeline: rx.Computed<mut wgpu.RenderPipeline>;
    globalsBuffer: mut wgpu.Buffer;
    globalsBindGroup: mut wgpu.BindGroup;

    instanceBuffer?: mut wgpu.Buffer = none;
    instanceBufferSize: int = 0;
    vertexBuffer: mut wgpu.Buffer;
    indexBuffer: mut wgpu.Buffer;

    // Font rendering
    fontAtlasTexture: mut wgpu.Texture;
    fontAtlasView: mut wgpu.TextureView;
    fontAtlasSampler: mut wgpu.Sampler;
    fontAtlasBindGroup: mut wgpu.BindGroup;
    fontRenderer: mut TextRenderer;

    primitives: []PrimitiveInstance = [];

    constructor(options: RendererOptions) {
        let queue = options.device.getQueue();
        if !queue { 
            sys.panic("Failed to get queue");
        }

        let vertexLayout = wgpu.VertexBufferLayout {
            arrayStride: sizeof(QuadVertex),
            stepMode: wgpu.VertexStepMode.Vertex,
            attributes: {
                {
                    shaderLocation: 0,
                    offset: 0,
                    format: wgpu.VertexFormat.Float32x2,
                },
            },
        };

        let instanceLayout = wgpu.VertexBufferLayout {
            arrayStride: sizeof(PrimitiveInstance),
            stepMode: wgpu.VertexStepMode.Instance, // key! this is per-instance
            attributes: {
                { shaderLocation: 1, offset: 0,  format: wgpu.VertexFormat.Float32x2 }, // pos
                { shaderLocation: 2, offset: 8,  format: wgpu.VertexFormat.Float32x2 }, // size

                { shaderLocation: 3, offset: 16, format: wgpu.VertexFormat.Float32 },   // radiusTopLeft
                { shaderLocation: 4, offset: 20, format: wgpu.VertexFormat.Float32 },   // radiusTopRight
                { shaderLocation: 5, offset: 24, format: wgpu.VertexFormat.Float32 },   // radiusBottomRight
                { shaderLocation: 6, offset: 28, format: wgpu.VertexFormat.Float32 },   // radiusBottomLeft

                { shaderLocation: 7, offset: 32, format: wgpu.VertexFormat.Float32 },   // borderThickness
                { shaderLocation: 8, offset: 36, format: wgpu.VertexFormat.Float32x4 }, // fillColor
                { shaderLocation: 9, offset: 52, format: wgpu.VertexFormat.Float32x4 }, // borderColor
                { shaderLocation: 10, offset: 68, format: wgpu.VertexFormat.Uint32 },   // type
                { shaderLocation: 11, offset: 72, format: wgpu.VertexFormat.Float32x2 },
                { shaderLocation: 12, offset: 80, format: wgpu.VertexFormat.Float32x2 },
            },
        };

        let globalsLayout = options.device.createBindGroupLayout({
            entries: {
                {
                    binding: 0,
                    visibility: wgpu.ShaderStage.Vertex,
                    buffer: { type: wgpu.BufferBindingType.Uniform },
                },
            },
        });

        let globalsBuffer = options.device.createBuffer({
            usage: wgpu.BufferUsage.Uniform | wgpu.BufferUsage.CopyDst,
            size: sizeof(Globals),
        });

        let globalsBindGroup = options.device.createBindGroup({
            layout: globalsLayout,
            entries: {
                {
                    binding: 0,
                    buffer: globalsBuffer,
                    offset: 0,
                    size: sizeof(Globals),
                },
            },
        });

        let textLayout = options.device.createBindGroupLayout({
            entries: {
                {
                    binding: 0,
                    visibility: wgpu.ShaderStage.Fragment,
                    texture: {
                        sampleType: wgpu.TextureSampleType.Float,
                        viewDimension: wgpu.TextureViewDimension._2D,
                        multisampled: false,
                    },
                },
                {
                    binding: 1,
                    visibility: wgpu.ShaderStage.Fragment,
                    sampler: { type: wgpu.SamplerBindingType.Filtering },
                },
            },
        });

        let pipelineLayout = options.device.createPipelineLayout({
            bindGroupLayouts: { globalsLayout, textLayout },
        });

        let shader = rx.computed<mut wgpu.ShaderModule>(() => {
            return options.device.createShaderModule({
                code: options.shadercode,
            });
        });

        let pipeline = rx.computed<mut wgpu.RenderPipeline>(() => {
            return options.device.createRenderPipeline({
                layout: pipelineLayout,
                vertex: {
                    module: shader,
                    entryPoint: "vs_main",
                    buffers: { vertexLayout, instanceLayout },
                },
                fragment: {
                    module: shader,
                    entryPoint: "fs_main",
                    targets: {
                        { 
                            format: options.surfaceFormats[0],
                            blend: {
                                color: {
                                    srcFactor: wgpu.BlendFactor.SrcAlpha,
                                    dstFactor: wgpu.BlendFactor.OneMinusSrcAlpha,
                                    operation: wgpu.BlendOperation.Add,
                                },
                                alpha: {
                                    srcFactor: wgpu.BlendFactor.One,
                                    dstFactor: wgpu.BlendFactor.OneMinusSrcAlpha,
                                    operation: wgpu.BlendOperation.Add,
                                },
                            },
                        },
                    },
                },
                primitive: {
                    topology: wgpu.PrimitiveTopology.TriangleList,
                },
            });
        });

        let vertexBuffer = options.device.createBuffer({
            usage: wgpu.BufferUsage.Vertex | wgpu.BufferUsage.CopyDst,
            size: sizeof(QuadVertex) * 4,
        });
        queue.writeBuffer<QuadVertex>(vertexBuffer, [
            { pos: Vec2f(-0.5, -0.5) },
            { pos: Vec2f(0.5, -0.5) },
            { pos: Vec2f(0.5, 0.5) },
            { pos: Vec2f(-0.5, 0.5) },
        ]);

        let indexBuffer = options.device.createBuffer({
            usage: wgpu.BufferUsage.Index | wgpu.BufferUsage.CopyDst,
            size: sizeof(u32) * 6,
        });
        queue.writeBuffer<u32>(indexBuffer, [0, 1, 2, 0, 2, 3]);

        let atlasSize = 1024;

        let fontAtlasTexture = options.device.createTexture({
            size: { width: atlasSize, height: atlasSize, depthOrArrayLayers: 1 },
            format: wgpu.TextureFormat.R8Unorm,
            usage: wgpu.TextureUsage.TextureBinding | wgpu.TextureUsage.CopyDst,
            mipLevelCount: 1,
            sampleCount: 1,
        });

        let fontAtlasView = fontAtlasTexture.createView();
        assert(fontAtlasView);

        let fontAtlasSampler = options.device.createSampler({
            minFilter: wgpu.FilterMode.Linear,
            magFilter: wgpu.FilterMode.Linear,
            maxAnisotropy: 1,
        });

        let fontAtlasBindGroup = options.device.createBindGroup({
            layout: textLayout,
            entries: {
                { binding: 0, textureView: fontAtlasView },
                { binding: 1, sampler: fontAtlasSampler },
            },
        });

        let fontRenderer = TextRenderer();

        return Renderer {
            windowSize: options.size,
            device: options.device,
            queue: queue,
            surface: options.surface,
            pipeline: pipeline,
            vertexBuffer: vertexBuffer,
            indexBuffer: indexBuffer,
            globalsBuffer: globalsBuffer,
            globalsBindGroup: globalsBindGroup,
            fontAtlasTexture: fontAtlasTexture,
            fontAtlasView: fontAtlasView,
            fontAtlasSampler: fontAtlasSampler,
            fontAtlasBindGroup: fontAtlasBindGroup,
            fontRenderer: fontRenderer,
        };
    }

    struct TriangleVertex {
        pos: Vec2;
        color: Color;
    };

    struct CornerRadius {
        topLeft: real = 0;
        topRight: real = 0;
        bottomLeft: real = 0;
        bottomRight: real = 0;
    };

    struct RectOpts {
        pos: Vec2;
        size: Vec2;
        fillColor: Color = { r: 1, g: 1, b: 1, a: 1 };
        cornerRadius: CornerRadius = {};
        borderColor: Color = { r: 1, g: 1, b: 1, a: 1 };
        borderThickness: real = 0;
    };

    drawRect(opts: RectOpts) {
        if opts.fillColor.a != 0.0 {
            this.primitives.push({
                type: 0, // Filled Rounded Rectangle
                pos: { x: (opts.pos.x + opts.size.x / 2.0) as f32, y: (opts.pos.y + opts.size.y / 2.0) as f32 },
                size: { x: opts.size.x as f32, y: opts.size.y as f32 },
                radiusTopLeft: opts.cornerRadius.topLeft as f32,
                radiusTopRight: opts.cornerRadius.topRight as f32,
                radiusBottomLeft: opts.cornerRadius.bottomLeft as f32,
                radiusBottomRight: opts.cornerRadius.bottomRight as f32,
                borderThickness: 0,
                fillColor: {
                    r: opts.fillColor.r as f32,
                    g: opts.fillColor.g as f32,
                    b: opts.fillColor.b as f32,
                    a: opts.fillColor.a as f32,
                },
                borderColor: { r: 0, g: 0, b: 0, a: 0 },
                uvMin: { x: 0, y: 0 },
                uvMax: { x: 0, y: 0 },
            });
        }
        if opts.borderColor.a != 0.0 && opts.borderThickness > 0.0 {
            this.primitives.push({
                type: 1, // Outlined Rounded Rectangle
                pos: { x: (opts.pos.x + opts.size.x / 2.0) as f32, y: (opts.pos.y + opts.size.y / 2.0) as f32 },
                size: { x: opts.size.x as f32, y: opts.size.y as f32 },
                radiusTopLeft: opts.cornerRadius.topLeft as f32,
                radiusTopRight: opts.cornerRadius.topRight as f32,
                radiusBottomLeft: opts.cornerRadius.bottomLeft as f32,
                radiusBottomRight: opts.cornerRadius.bottomRight as f32,
                borderThickness: opts.borderThickness as f32,
                fillColor: { r: 0, g: 0, b: 0, a: 0 },
                borderColor: {
                    r: opts.borderColor.r as f32,
                    g: opts.borderColor.g as f32,
                    b: opts.borderColor.b as f32,
                    a: opts.borderColor.a as f32,
                },
                uvMin: { x: 0, y: 0 },
                uvMax: { x: 0, y: 0 },
            });
        }
    }

    struct TextOpts {
        font: int;
        position: Vec2;
        size: real;
        text: str;
        color: Color;
    }

    drawText(
        opts: TextOpts
    ) {
        this.fontRenderer.drawText(
            this,
            opts.font,
            opts.size as f32,
            opts.position.x as f32,
            opts.position.y as f32,
            opts.text,
            opts.color
        );
    }

    updateAtlas() {
        let atlas = this.fontRenderer.fs.getAtlas()

        this.queue.writeTexture(
            { texture: this.fontAtlasTexture },
            atlas.pixels,
            atlas.width * atlas.height,
            { offset: 0, bytesPerRow: atlas.width, rowsPerImage: atlas.height },
            { width: atlas.width, height: atlas.height, depthOrArrayLayers: 1 }
        );
    }

    beginFrame() {
        this.primitives = [];
    }

    endFrame() {
        let pipelineValue = rx.unwrap(this.pipeline);

        this.updateAtlas();

        let surfaceTexture = this.surface.getCurrentTexture();
        if !surfaceTexture.texture { 
            fmt.println("Failed to get surface texture"); 
            return;
        }

        let backbuffer = surfaceTexture.texture.createView();
        if !backbuffer { 
            fmt.println("Failed to create texture view"); 
            return;
        }

        let encoder = this.device.createCommandEncoder();
        if !encoder { 
            fmt.println("Failed to create command encoder"); 
            return;
        }

        this.queue.writeBuffer<Globals>(
            this.globalsBuffer,
            [
                {
                    screenSize: Vec2f(
                        this.windowSize.x as f32,
                        this.windowSize.y as f32
                    ),
                }
            ]
        );

        let requiredInstanceBufferSize = sizeof(type<PrimitiveInstance>) * this.primitives.length;
        if (!this.instanceBuffer || requiredInstanceBufferSize > this.instanceBufferSize) {
            // Grow efficiently, at least double, or more if required
            this.instanceBufferSize = max(requiredInstanceBufferSize, this.instanceBufferSize * 2);
            this.instanceBuffer = this.device.createBuffer({
                size: this.instanceBufferSize,
                usage: wgpu.BufferUsage.Vertex | wgpu.BufferUsage.Storage | wgpu.BufferUsage.CopyDst,
            });
        }
        assert(this.instanceBuffer);
        this.queue.writeBuffer<PrimitiveInstance>(this.instanceBuffer, this.primitives);

        let colorAttachment = wgpu.RenderPassColorAttachment {
            view: backbuffer,
            clearValue: Color(0, 0, 0, 0),
            loadOp: wgpu.LoadOp.Clear,
            storeOp: wgpu.StoreOp.Store,
        };

        let renderPassDescriptor = wgpu.RenderPassDescriptor {
            colorAttachments: {
                colorAttachment,
            },
        };
        let renderPass = encoder.beginRenderPass(renderPassDescriptor);
        if !renderPass { 
            fmt.println("Failed to create render pass"); 
            return;
        }

        renderPass.setPipeline(pipelineValue);
        renderPass.setVertexBuffer(0, this.vertexBuffer);

        renderPass.setBindGroup(0, this.globalsBindGroup);
        renderPass.setBindGroup(1, this.fontAtlasBindGroup);

        renderPass.setViewport(0, 0, this.windowSize.x as real, this.windowSize.y as real, 0.0, 1.0);
        renderPass.setScissorRect(0, 0, this.windowSize.x, this.windowSize.y);

        renderPass.setIndexBuffer(this.indexBuffer, wgpu.IndexFormat.Uint32);
        renderPass.setVertexBuffer(1, this.instanceBuffer);

        renderPass.drawIndexed(6, this.primitives.length, 0, 0, 0);

        renderPass.end();

        let commandBuffer = encoder.finish();
        if !commandBuffer { 
            fmt.println("Failed to finish render pass and get command buffer"); 
            return;
        }

        this.queue.submit({ commandBuffer });
        if !this.surface.present() {
            fmt.println("Surface present failed");
            return;
        }
    }
}
