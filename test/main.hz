
import sdl
import gl
import wgpu
import sdl_wgpu

// ui framework module (includes flexbox layout)
import ui

export extern C noemit wgpu_init(window: cptr) :: final;
export extern C wgpu_start(window: cptr, device: wgpu.ffi.WGPUDeviceImpl, surface: wgpu.ffi.WGPUSurfaceImpl, queue: wgpu.ffi.WGPUQueueImpl, texture: wgpu.ffi.WGPUTextureViewImpl) :: final;
export extern C wgpu_end(window: cptr) :: final;

getWindowState(window: sdl.Window): WindowState {
    let logicalSize = window.getLogicalSize();
    let framebufferSize = window.getFramebufferSize();

    let dpiScaleX = 1.0 as f32;
    let dpiScaleY = 1.0 as f32;
    if logicalSize.x > 0 {
        dpiScaleX = framebufferSize.x as f32 / logicalSize.x as f32;
    }
    if logicalSize.y > 0 {
        dpiScaleY = framebufferSize.y as f32 / logicalSize.y as f32;
    }

    // SDL typically reports uniform scale factors on desktop systems.
    let dpiScale = (dpiScaleX + dpiScaleY) / (2.0 as f32);

    return WindowState {
        logicalSize: logicalSize,
        framebufferSize: framebufferSize,
        dpiScale: dpiScale,
    };
}

main(): int {

    attempt {
        if !sdl.init() { raise "SDL init failed"; }

        const window = sdl.createWindow({ 
            title: "WebGPU Example",
            noApi: true,
        });
        if !window { raise "Window creation failed"; }

        let instance = wgpu.createInstance();
        if !instance { raise "WGPU Instance creation failed"; }

        let surface = sdl_wgpu.createWindowWGPUSurface(instance, window);
        if !surface { raise "WGPU Surface creation failed"; }

        let adapter = none as mut wgpu.Adapter | none;
        let adapterReady = false;
        instance.requestAdapter({}, { 
            callback: (status: wgpu.RequestAdapterStatus, _adapter: mut wgpu.Adapter, message: str): void => {
                if (status == wgpu.RequestAdapterStatus.Success) {
                    adapter = _adapter;
                    adapterReady = true;
                    fmt.println("Adapter request successful");
                }
                else {
                    adapterReady = true;
                    fmt.println("Adapter request failed");
                }
            }
        });
        let timeout = 100;
        while !adapterReady && timeout > 0 {
            time.sleep(0.1);
            timeout--;
        }
        if (!adapter) { raise "Failed to get adapter after timeout"; }

        let device = none as mut wgpu.Device | none;
        let deviceReady = false;
        adapter.requestDevice({}, { 
            callback: (status: wgpu.RequestDeviceStatus, _device: mut wgpu.Device, message: str): void => {
                if (status == wgpu.RequestDeviceStatus.Success) {
                    device = _device;
                    deviceReady = true;
                    fmt.println("Device request successful");
                }
                else {
                    deviceReady = true;
                    fmt.println("Device request failed");
                }
            }
        });

        timeout = 100;
        while !deviceReady && timeout > 0 {
            time.sleep(0.1);
            timeout--;
        }
        if (!device) { raise "Failed to get device after timeout"; }

        let caps = surface.getCapabilities(adapter);
        if (!caps) { raise "Failed to get surface capabilities"; }

        let windowState = getWindowState(window);
        surface.configure({
            device: device,
            format: caps.formats[0],
            usage: wgpu.TextureUsage.RenderAttachment,
            width: windowState.framebufferSize.x,
            height: windowState.framebufferSize.y,
            presentMode: wgpu.PresentMode.Fifo,
            alphaMode: caps.alphaModes[0],
        });

        let comptime enableShaderHotreload = true;
        let renderer = Renderer({
            windowState: windowState,
            device: device, 
            surface: surface, 
            surfaceFormats: caps.formats,
            shadercode: embed.watchTextIf(enableShaderHotreload, "test/shaders.wgsl"),
        });

        let font = renderer.fontRenderer.fs.addFont(
            "roboto-regular",
            "test/Roboto-Regular.ttf"
        );

        ui.init(windowState.logicalSize.x, windowState.logicalSize.y);
        let uiTree = rx.reactive<ui.DivElement>(ui.DivElement {
            id: 1,
            style: {
                backgroundColor: Color(0.15, 0.15, 0.15, 1),
                padding: ui.StylePaddingSimple { value: 30.0 },
                direction: ui.Direction.Column,
                gap: 10,
            },
            children: [

                // header
                ui.DivElement {
                    id: 2,
                    style: {
                        backgroundColor: Color(0.9, 0.2, 0.2, 1),
                        padding: ui.StylePaddingSimple { value: 20.0 },
                        align: ui.Align.Center,
                        cornerRadius: ui.StyleCornerRadiusSimple {
                            value: 10.0
                        },
                    },
                    children: [
                        ui.TextElement {
                            id: 10,
                            text: "HAZE UI TEST",
                            style: {
                                fontSize: 42,
                                font: font,
                            }
                        }
                    ]
                },

                // main row container
                ui.DivElement {
                    id: 3,
                    style: {
                        direction: ui.Direction.Row,
                        padding: ui.StylePaddingSimple { value: 20.0 },
                        backgroundColor: Color(0.25, 0.25, 0.25, 1),
                        justify: ui.Justify.SpaceBetween,
                        cornerRadius: ui.StyleCornerRadiusSimple {
                            value: 20.0
                        },
                        gap: 30,
                    },
                    children: [

                        // sidebar
                        ui.DivElement {
                            id: 4,
                            style: {
                                backgroundColor: Color(0.2, 0.6, 0.9, 1),
                                padding: ui.StylePaddingSimple { value: 20.0 },
                                direction: ui.Direction.Column,
                            },
                            children: [
                                ui.TextElement { id: 11, text: "Menu", style: { fontSize: 32, font: font } },
                                ui.TextElement { id: 12, text: "Dashboard", style: { fontSize: 32, font: font } },
                                ui.TextElement { id: 13, text: "Settings", style: { fontSize: 32, font: font } },
                                ui.TextElement { id: 14, text: "About", style: { fontSize: 32, font: font } },
                            ]
                        },

                        // content panel
                        ui.DivElement {
                            id: 5,
                            style: {
                                backgroundColor: Color(0.2, 0.8, 0.4, 1),
                                padding: ui.StylePaddingSimple { value: 30.0 },
                                direction: ui.Direction.Column,
                                align: ui.Align.Center,
                            },
                            children: [
                                ui.TextElement {
                                    id: 15,
                                    text: "Welcome to the content area!",
                                    style: { fontSize: 32, font: font }
                                },
                                ui.TextElement {
                                    id: 16,
                                    text: "Flexbox layout test",
                                    style: { fontSize: 32, font: font }
                                },
                            ]
                        },

                        // right column
                        ui.DivElement {
                            id: 6,
                            style: {
                                backgroundColor: Color(0.9, 0.8, 0.2, 1),
                                padding: ui.StylePaddingSimple { value: 20.0 },
                                direction: ui.Direction.Column,
                                justify: ui.Justify.Center,
                                align: ui.Align.Center,
                            },
                            children: [
                                ui.TextElement {
                                    id: 17,
                                    text: "Info Box",
                                    style: { fontSize: 32, font: font }
                                },
                                ui.TextElement {
                                    id: 18,
                                    text: "Aligned center",
                                    style: { fontSize: 32, font: font }
                                }
                            ]
                        }
                    ]
                },

                // footer
                ui.DivElement {
                    id: 7,
                    style: {
                        backgroundColor: Color(0.4, 0.4, 0.9, 1),
                        padding: ui.StylePaddingSimple { value: 15.0 },
                        align: ui.Align.Center,
                    },
                    children: [
                        ui.TextElement {
                            id: 19,
                            text: "Footer text",
                            style: { fontSize: 20, font: font }
                        }
                    ]
                }
            ]
        });

        while !window.shouldClose() {
            sdl.pollEvents();

            if window.consumeSizeChanged() {
                let nextWindowState = getWindowState(window);
                if nextWindowState.framebufferSize.x > 0 && nextWindowState.framebufferSize.y > 0 {
                    surface.configure({
                        device: device,
                        format: caps.formats[0],
                        usage: wgpu.TextureUsage.RenderAttachment,
                        width: nextWindowState.framebufferSize.x,
                        height: nextWindowState.framebufferSize.y,
                        presentMode: wgpu.PresentMode.Fifo,
                        alphaMode: caps.alphaModes[0],
                    });
                    renderer.updateWindowState(nextWindowState);
                    ui.setLayoutSize(nextWindowState.logicalSize.x, nextWindowState.logicalSize.y);
                }
            }

            fs.pollEvents();
            renderer.beginFrame();

            ui.layoutTree(rx.unwrap(uiTree), {
                renderFilledRectangle: (position: Vec2, size: Vec2, backgroundColor: Color, cornerRadius: ui.CornerRadiusValues): void => {
                    renderer.drawRect({
                        pos: position, 
                        size: size,
                        fillColor: backgroundColor,
                        cornerRadius: {
                            topLeft: cornerRadius.topLeft,
                            topRight: cornerRadius.topRight,
                            bottomLeft: cornerRadius.bottomLeft,
                            bottomRight: cornerRadius.bottomRight,
                        },
                        // cornerRadius: 30,
                        // borderThickness: 1,
                        // borderColor: Color(0, 1, 0, 1),
                    });
                },
                renderText: (element: ui.ffi.hzui_draw_text_element_t): void => {
                    // fmt.println("Drawing text", fontSize, position.x, position.y, text, textColor.r, textColor.g, textColor.b, textColor.a);
                    // renderer.drawRect({
                    //     pos: element.position, 
                    //     size: element.size,
                    //     fillColor: Color(0, 0, 0, 1),
                    // });
                    renderer.drawText({
                        font: element.fontId,
                        size: element.fontSize,
                        position: element.position,
                        text: element.text,
                        color: element.color,
                    });
                }
            });

            // renderer.drawText({
            //     font: font,
            //     size: 42,
            //     position: Vec2(100, 100),
            //     text: "Hello World",
            //     color: Color(1, 0, 0, 1),
            // });

            // renderer.drawRect({
            //     pos: Vec2(100, 100), 
            //     size: Vec2(200, 200), 
            //     fillColor: Color(1, 0, 0, 1),
            //     cornerRadius: 30,
            //     borderThickness: 1,
            //     borderColor: Color(0, 1, 0, 1),
            // });
            // renderer.drawRect({
            //     pos: Vec2(200, 400), 
            //     size: Vec2(300, 200), 
            //     fillColor: Color(1, 0, 1, 1),
            //     cornerRadius: 3,
            //     borderThickness: 2,
            //     borderColor: Color(0, 1, 0, 1),
            // });
            // renderer.drawRect({
            //     pos: Vec2(250, 350), 
            //     size: Vec2(300, 200), 
            //     fillColor: Color(1.0, 0.6549, 0.0588, 1),
            //     cornerRadius: 30,
            //     borderThickness: 3,
            //     borderColor: Color(0, 1, 0, 1),
            // });

            renderer.endFrame();
        }

        window.destroy();
        sdl.terminate();
        
        return 0;
    }
    else e {
        if e is str {
            fmt.println("Application failed: ", e);
        }
        else if e is fs.Error {
            fmt.println("Application failed: ", e);
        }
        else if e is none {
            fmt.println("Application failed: ", e);
        }
        else {
            fmt.println("Application failed: ", e);
        }
        return 1;
    };
}

    // fmt.println("TODO: Implement a proper platform configuration system. Currently there is an interface.compiler.defines feature to define transitive macros, but this is not the solution, it is only a workaround. We rather want a real, proper configuration system where we can e.g. differentiate between x11 and wayland platform configurations and compile for one of them.");

//     fmt.println("TODO: Fix returns, if function returns in one path but not all, it must either create an error or automatically return none");
