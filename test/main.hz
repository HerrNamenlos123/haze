
import tesselate
import perfect_freehand
import sdl
import gl
import wgpu
import sdl_wgpu

// ui framework module (includes flexbox layout)
import hzui

export extern C noemit fn wgpu_init(window: cptr) :: final;
export extern C fn wgpu_start(window: cptr, device: wgpu.ffi.WGPUDeviceImpl, surface: wgpu.ffi.WGPUSurfaceImpl, queue: wgpu.ffi.WGPUQueueImpl, texture: wgpu.ffi.WGPUTextureViewImpl) :: final;
export extern C fn wgpu_end(window: cptr) :: final;

fn getWindowState(window: sdl.Window): gfx.CanvasSize {
    let logicalSize = window.getLogicalSize();
    let framebufferSize = window.getFramebufferSize();

    let dpiScaleX = logicalSize.x > 0 ? framebufferSize.x as real / logicalSize.x as real : 1.0;
    let dpiScaleY = logicalSize.y > 0 ? framebufferSize.y as real / logicalSize.y as real : 1.0;

    // SDL typically reports uniform scale factors on desktop systems.
    let dpiScale = (dpiScaleX + dpiScaleY) / 2.0;

    return gfx.CanvasSize {
        logicalSize: logicalSize,
        framebufferSize: framebufferSize,
        dpiScale: dpiScale as f32,
    };
}

fn print<T>(value: T) {
    if comptime typeof(value).category == meta.TypeCategory.Struct {
        let s = "{\n";
        for comptime field, i in typeof(value).fields {
            s += f"    {field.name}: {value.[field.name]}{i < typeof(value).fields.length - 1 ? "," : ""}\n";
        }
        s += "}";
        fmt.println(s);
    }
    else {
        fmt.println(value);
    }
}

struct Point {
    x: real;
    y: real;
    pressure: real;
}

struct Shape {
    variant: str;
    points: []Point;
    penThickness: real;
    penColor: str;
}

struct Page {
    shapes: []Shape;
}

struct FileData {
    pageColor: str;
    gridColor: str;
    gridType: str;
    pages: []Page;
}

struct Test2 {}

struct File {
    filetype: str;
    fileVersion: int;
    data: FileData;
}

struct ShapeOutline {
    outline: [][2]real;
}

struct OutlineFile {
    shapes: []ShapeOutline;
}

fn loadTskTest() {
    let file = fs.readText("Test.tsk");
    if !file {
        fmt.println("File loading failed");
        return;
    }

    let j = json.parse(file);
    // fmt.println(j);

    let result = json.structuredParse<File>(file);
    if result {
        let data: File = result;
        fmt.println("Parsed successfully");
    }
    else {
        fmt.println("Failed parsing: ", result);
    }
}

fn loadTskOutlines() {
    let file = fs.readText("test-raw-outline.tsk");
    if !file {
        fmt.println("File loading failed");
        return;
    }

    let result = json.structuredParse<OutlineFile>(file);
    if result {
        fmt.println("Parsed successfully");
        fmt.println(f"{result.shapes.length} shapes");
    }
    else {
        fmt.println("Failed parsing: ", result);
    }
}

fn testTesselator() {
    fmt.println("--- Tesselator test ---");

    let tess = tesselate.Tesselator();
    tess.beginPath();
    tess.moveTo(Vec2(0.0, 0.0));
    tess.lineTo(Vec2(100.0, 0.0));
    tess.lineTo(Vec2(100.0, 100.0));
    tess.lineTo(Vec2(0.0, 100.0));
    tess.closePath();

    let result = tess.tessellate(0.1);
    if result {
        fmt.println(f"  {result.vertices.length} vertices, {result.indices.length / 3} triangles:");
        let i = 0;
        while i < result.vertices.length {
            fmt.println(f"  v[{i}] = ({result.vertices[i].x}, {result.vertices[i].y})");
            i++;
        }
        i = 0;
        while i < result.indices.length / 3 {
            fmt.println(f"  tri[{i}] = {result.indices[i * 3]}, {result.indices[i * 3 + 1]}, {result.indices[i * 3 + 2]}");
            i++;
        }
    }
    else {
        fmt.println("  Tessellation failed");
    }

    tess.destroy();
    fmt.println("-----------------------");
}

fn testPerfectFreehand() {
    fmt.println("--- PerfectFreehand test ---");

    let pf = perfect_freehand.PerfectFreehand(perfect_freehand.StrokeOptions {
        size: 16.0,
        thinning: 0.5,
        smoothing: 0.5,
        streamline: 0.5,
        simulatePressure: true,
        last: true,
    });

    pf.addPoint(Vec2(0.0, 0.0));
    pf.addPoint(Vec2(50.0, 25.0));
    pf.addPoint(Vec2(100.0, 0.0));
    pf.addPoint(Vec2(150.0, 50.0));
    pf.addPoint(Vec2(200.0, 0.0));

    let outline = pf.compute();
    if outline {
        fmt.println(f"  Outline has {outline.length} points");
        let i = 0;
        while i < outline.length && i < 5 {
            fmt.println(f"  pt[{i}] = ({outline[i].x}, {outline[i].y})");
            i++;
        }
    }
    else {
        fmt.println("  PerfectFreehand compute failed");
    }

    pf.destroy();
    fmt.println("----------------------------");
}

fn heavierWork(v: Box<int>) {
    v.value++;
}

fn heavyWork() {
    let v = Box<int>(0); 
    for (let i = 0; i < 1000000; i++) {
        heavierWork(v);
    }
}

fn main(): int {

    let profiler = Profiler();

    let start = time.now();
    fmt.println(f"Running");
    for (let i = 0; i < 100; i++) {
        fmt.println(f"Iteration {i}");
        heavyWork();
    }
    fmt.println(f"Done, ran for {time.now() - start} seconds");

    let result = profiler.end();

    fmt.println(f"Profiling done: {result.samples.length} samples, {result.frames.length} unique frames, {result.sampling_rate_hz} Hz");
    for (let i = 0; i < result.frames.length && i < 5; i++) {
        let frame = result.frames[i];
        let address = 0;
        do unsafe {
            __c__("address = (hzstd_int_t)frame.address;");
        };
        let loc = frame.sourceloc.filename() ? f"{frame.sourceloc.filename()}:{frame.sourceloc.line()}" : "<no source info>";
        fmt.println(f"  frame[{i}] {frame.name} @ {address} ({loc})");
    }
    if result.samples.length > 0 {
        let sample = result.samples[0];
        fmt.println(f"  sample[0] t={sample.timestamp}s overhead={sample.sampling_duration}s depth={sample.frames.length}");
    }

    return 0;

    attempt {
        if !sdl.init() { raise "SDL init failed"; }

        const window = sdl.createWindow({ 
            title: "WebGPU Example",
            noApi: true,
        });
        if !window { raise "Window creation failed"; }

        let instance = wgpu.createInstance();
        if !instance { raise "WGPU Instance creation failed"; }

        let surface = sdl_wgpu.createWindowWGPUSurface(instance, window);
        if !surface { raise "WGPU Surface creation failed"; }

        let adapter = none as mut wgpu.Adapter | none;
        let adapterReady = false;
        instance.requestAdapter({}, { 
            callback: (status: wgpu.RequestAdapterStatus, _adapter: mut wgpu.Adapter, message: str): void => {
                if (status == wgpu.RequestAdapterStatus.Success) {
                    adapter = _adapter;
                    adapterReady = true;
                    fmt.println("Adapter request successful");
                }
                else {
                    adapterReady = true;
                    fmt.println("Adapter request failed");
                }
            }
        });
        let timeout = 100;
        while !adapterReady && timeout > 0 {
            time.sleep(0.1);
            timeout--;
        }
        if (!adapter) { raise "Failed to get adapter after timeout"; }

        let device = none as mut wgpu.Device | none;
        let deviceReady = false;
        adapter.requestDevice({}, { 
            callback: (status: wgpu.RequestDeviceStatus, _device: mut wgpu.Device, message: str): void => {
                if (status == wgpu.RequestDeviceStatus.Success) {
                    device = _device;
                    deviceReady = true;
                    fmt.println("Device request successful");
                }
                else {
                    deviceReady = true;
                    fmt.println("Device request failed");
                }
            }
        });

        timeout = 100;
        while !deviceReady && timeout > 0 {
            time.sleep(0.1);
            timeout--;
        }
        if (!device) { raise "Failed to get device after timeout"; }

        let caps = surface.getCapabilities(adapter);
        if (!caps) { raise "Failed to get surface capabilities"; }

        let windowState = getWindowState(window);
        surface.configure({
            device: device,
            format: caps.formats[0],
            usage: wgpu.TextureUsage.RenderAttachment,
            width: windowState.framebufferSize.x,
            height: windowState.framebufferSize.y,
            presentMode: wgpu.PresentMode.Fifo, // VSYNC=ON
            // presentMode: wgpu.PresentMode.Mailbox, // VSYNC=OFF
            // presentMode: wgpu.PresentMode.Immediate, // VSYNC=OFF
            alphaMode: caps.alphaModes[0],
        });

        const comptime enableShaderHotreload = true;
        let gfxCtx = gfx.Context({
            device: device,
            targetFormat: caps.formats[0],
            shadercode: embed.watchTextIf(enableShaderHotreload, "test/shaders.wgsl"),
        });

        let canvas = gfx.Canvas({
            gfx: gfxCtx,
            size: windowState,
            surface: surface,
        });

        let font = gfxCtx.fontRenderer.fs.addFont(
            "roboto-regular",
            "test/Roboto-Regular.ttf"
        );

        let fonts: []hzui.FontEntry = [
            {
                name: "default",
                id: gfxCtx.fontRenderer.defaultFont,
            },
            {
                name: "roboto",
                id: font,
            }
        ];

        let uiCtx = hzui.Context({
            width: windowState.logicalSize.x,
            height: windowState.logicalSize.y,
            fonts: fonts,
            getFontLineHeight: (fontId: int, fontSize: real): real => {
                let metrics = gfxCtx.fontRenderer.fs.getMetrics(fontId, fontSize);
                return metrics.lineh;
            },
        });

        // Load TSK Shapes
        let testTsk = fs.readText("Test.tsk");
        if !testTsk {
            fmt.println("File loading failed");
            return 0;
        }

        let s1 = time.now();
        json.parse(testTsk);
        fmt.println(f"Parsed raw json in {time.now() - s1} seconds");

        let s2 = time.now();
        let result = json.structuredParse<File>(testTsk);
        fmt.println(f"Parsed structured json in {time.now() - s2} seconds");

        // Tessellate outlines once before the loop
        let start = time.now();
        let tesselatedShapes: []tesselate.TesselationResult = [];
        let count = 0;

        if result {
            let data: File = result;
            let page = data.data.pages[0];
            fmt.println("Parsed successfully");

            let accuracyScaling = 10.0;
            let tess = tesselate.Tesselator();
            count = page.shapes.length;
            for (let s = 0; s < page.shapes.length; s++) {
                let shape = page.shapes[s];

                // Perfect Freehand
                let pf = perfect_freehand.PerfectFreehand({
                    size: shape.penThickness * accuracyScaling,
                    thinning: 0.1,
                    smoothing: 0.0,
                    streamline: 0.6,
                    simulatePressure: false,
                    last: true,
                });

                for point in shape.points {
                    pf.addPoint({
                        x: point.x * accuracyScaling,
                        y: point.y * accuracyScaling,
                    });
                }

                let points: []Vec2 = [];
                let outline = pf.compute();
                if outline {
                    fmt.println(f"  Outline has {outline.length} points");
                    points = outline;
                }
                else {
                    fmt.println("  PerfectFreehand compute failed");
                }

                pf.destroy();
                fmt.println("----------------------------");

                // Now tesselate
                if points.length > 0 {
                    tess.beginPath();
                    tess.moveTo(Vec2(points[0].x / accuracyScaling, points[0].y / accuracyScaling));
                    for (let p = 1; p < points.length; p++) {
                        tess.lineTo(Vec2(points[p].x / accuracyScaling, points[p].y / accuracyScaling));
                    }
                    tess.closePath();
                    let result = tess.tessellate(0.25);
                    if result { tesselatedShapes.push(result); }
                }
            }
            tess.destroy();
            fmt.println(f"Tessellated {tesselatedShapes.length} shapes");
        }
        else {
            fmt.println("Failed parsing: ", result);
        }
        let end = time.now();
        fmt.println(f"Tesselated {count} shapes in {(end - start) * 1000.0} ms");

        let down = false;
        let mousePosition = Vec2(0, 0);
        window.onMouseMove((e: sdl.MouseMoveEvent) => {
            mousePosition.x = e.pos.x;
            mousePosition.y = e.pos.y;
            return false;
        });

        window.onKeyDown((e: sdl.KeyEvent) => {
            down = true;
            return false;
        });

        window.onKeyUp((e: sdl.KeyEvent) => {
            down = false;
            return false;
        });

        let ui = UIContext({
            ui: (ui: UIContext) => UI(ui),
            mousePos: () => mousePosition as Vec2,
        });

        for (let s = 0; s < tesselatedShapes.length; s++) {
            let shape = tesselatedShapes[s];

            for (let i = 0; i < shape.vertices.length; i++) {
                shape.vertices[i].x = (shape.vertices[i].x - 100.0) * 20.0;
                shape.vertices[i].y = (shape.vertices[i].y - 200.0) * 20.0;
            }
        }

        let pMousePosition = Vec2(0, 0);
        let dMousePosition = Vec2(0, 0);
        while !window.shouldClose() {
            sdl.pollEvents();
            dMousePosition.x = mousePosition.x - pMousePosition.x;
            dMousePosition.y = mousePosition.y - pMousePosition.y;
            pMousePosition = mousePosition;

            if window.consumeSizeChanged() {
                let now = time.now();
                let nextWindowState = getWindowState(window);
                if nextWindowState.framebufferSize.x > 0 && nextWindowState.framebufferSize.y > 0 {
                    surface.configure({
                        device: device,
                        format: caps.formats[0],
                        usage: wgpu.TextureUsage.RenderAttachment,
                        width: nextWindowState.framebufferSize.x,
                        height: nextWindowState.framebufferSize.y,
                        presentMode: wgpu.PresentMode.Fifo,
                        alphaMode: caps.alphaModes[0],
                    });
                    canvas.resize(nextWindowState);
                    hzui.setLayoutSize(nextWindowState.logicalSize.x, nextWindowState.logicalSize.y);
                }
            }

            fs.pollEvents();
            let renderer = gfx.Renderer(canvas);

            let tree = ui.process();

            uiCtx.render(tree, {
                renderFilledRectangle: (position: Vec2, size: Vec2, backgroundColor: Color, cornerRadius: hzui.CornerRadiusValues): void => {
                    renderer.drawRect({
                        pos: position, 
                        size: size,
                        fillColor: backgroundColor,
                        cornerRadius: {
                            topLeft: cornerRadius.topLeft,
                            topRight: cornerRadius.topRight,
                            bottomLeft: cornerRadius.bottomLeft,
                            bottomRight: cornerRadius.bottomRight,
                        },
                    });
                },
                renderText: (element: hzui.ffi.hzui_draw_text_element_t): void => {
                    renderer.drawText({
                        font: element.fontId,
                        size: element.fontSize,
                        position: element.position,
                        text: element.text,
                        color: element.color,
                    });
                }
            });

            // Render tessellated shapes
            for (let s = 0; s < tesselatedShapes.length; s++) {
                let shape = tesselatedShapes[s];

                for (let i = 0; i < shape.vertices.length; i++) {
                    if (down) {
                        shape.vertices[i].x = shape.vertices[i].x + dMousePosition.x;
                        shape.vertices[i].y = shape.vertices[i].y + dMousePosition.y;
                    }
                }

                // renderer.addTriangles(shape.vertices, shape.indices, Color { r: 0.2, g: 0.5, b: 0.9, a: 1.0 });
                renderer.addTriangles(shape.vertices, shape.indices, "#000");
            }

            renderer.commit();
        }

        window.destroy();
        sdl.terminate();
        
        return 0;
    }
    else e {
        if e is str {
            fmt.println("Application failed: ", e);
        }
        else if e is fs.Error {
            fmt.println("Application failed: ", e);
        }
        else if e is none {
            fmt.println("Application failed: ", e);
        }
        else {
            fmt.println("Application failed: ", e);
        }
        return 1;
    };
}

    // fmt.println("TODO: Implement a proper platform configuration system. Currently there is an interface.compiler.defines feature to define transitive macros, but this is not the solution, it is only a workaround. We rather want a real, proper configuration system where we can e.g. differentiate between x11 and wayland platform configurations and compile for one of them.");

//     fmt.println("TODO: Fix returns, if function returns in one path but not all, it must either create an error or automatically return none");
//     fmt.println("Idea for later: (from Prime Reacts: The Flaws of Inheritance): I should implement interfaces as a way to make a contract about generic types, and to make the interfaces very powerful, interfaces should be able to define members and methods, as well as default implementations of methods that is used if the struct does not provide that function, and it is allowed as long as the default implementation of the interface method only uses other methods of the interface. This makes it very powerful and a complete replacement for polymorphism.");
//     fmt.println("Idea: Implement scopes/do blocks/whatever, and like in Swift make the ability to label them, and then 'break foo' can be used to break out of that scope, which is awesome because it greatly simplifies the common issue of having 2 nested loops and wanting to break out of the outer one.")

// ============================================================================
// === Unified Compile-Time Model: Types, Expressions, and Comptime Functions ===
// ============================================================================
//
// Core Idea:
// The language has ONE semantic model: expressions that can evaluate at compile time.
// Types are not a separate system — they are compile-time values (TypeInfo).
//
// However, syntax remains structured to keep parsing, tooling, and readability sane.
//
// ----------------------------------------------------------------------------
// 1. Types as Expressions (Semantic Rule)
// ----------------------------------------------------------------------------
//
// Any expression can conceptually be used in a type position.
// BUT:
//
//   - It must be fully comptime evaluable
//   - It must evaluate to CTValue(kind = "type")
//
// Otherwise → compiler error.
//
// Example:
//
//   const T = underlyingType(typeof(value));
//   const x: Foo<T>;                            // OK
//   const y: Foo<typeof(value)>;               // OK
//   const z: Foo<underlyingType(typeof(value))>; // OK
//
// Implementation:
//
//   const ct = evalCT(expr);
//   if (!ct || ct.kind !== "type") {
//       error("type expression must evaluate to a type");
//   }
//
// ----------------------------------------------------------------------------
// 2. Syntax vs Semantics
// ----------------------------------------------------------------------------
//
// Semantics:
//   - Any expression can produce a type
//
// Syntax:
//   - Parser restricts allowed syntax in type positions to "sane" constructs
//   - Avoid full arbitrary expressions to prevent:
//       - parsing ambiguity
//       - poor diagnostics
//       - dependent type complexity
//
// Allowed (initially):
//   - Type identifiers: int, Foo
//   - Generic instantiation: Foo<T>
//   - typeof(expr)
//   - Comptime functions: underlyingType(...)
//   - Identifiers bound to comptime type values
//
// Not allowed (for now):
//   - Arbitrary runtime expressions
//   - Non-comptime values
//   - Expressions that do not evaluate to a type
//
// ----------------------------------------------------------------------------
// 3. CTValue System (Single Evaluation Model)
// ----------------------------------------------------------------------------
//
// Compile-time evaluation produces CTValue:
//
//   - primitives (int, string, etc.)
//   - struct values
//   - lists
//   - types (TypeInfo)
//
// Types are simply:
//
//   CTValue { kind: "type", value: TypeInfo }
//
// There is no separate "meta.Type" system conceptually.
//
// ----------------------------------------------------------------------------
// 4. Comptime Evaluation
// ----------------------------------------------------------------------------
//
// evalCT(expr):
//   - Attempts to evaluate expression at compile time
//   - Returns CTValue or null
//
// Used for:
//   - const initialization
//   - if comptime
//   - static_print / static_assert
//   - type expressions
//
// ----------------------------------------------------------------------------
// 5. Comptime Functions
// ----------------------------------------------------------------------------
//
// Syntax:
//
//   comptime fn foo(...) -> ... { ... }
//
// Semantics:
//
//   - MUST be evaluated at compile time
//   - Cannot fall back to runtime
//   - If evaluation fails → compiler error
//   - Not emitted as runtime code
//
// Used for:
//   - type transformations
//   - reflection helpers
//   - compile-time logic
//
// Example:
//
//   comptime fn baseType(T: Type) -> Type {
//       return T.baseType;
//   }
//
//   const x: baseType(typeof(value));
//
// ----------------------------------------------------------------------------
// 6. Normal Functions
// ----------------------------------------------------------------------------
//
//   fn foo(...) { ... }
//
// Semantics:
//
//   - Runtime by default
//   - (Future): may be evaluated at compile time if:
//       - all arguments are CTValues
//       - function is pure
//
// This enables "constant folding on steroids" later,
// but is NOT required for initial implementation.
//
// ----------------------------------------------------------------------------
// 7. Function Calls and CT Evaluation
// ----------------------------------------------------------------------------
//
// When resolving a call:
//
//   if (fn is comptime fn):
//       evaluate via evalCT
//       if fails → error
//
//   else:
//       (future) try CT evaluation if possible
//       otherwise → runtime call
//
// ----------------------------------------------------------------------------
// 8. Types vs Values (Important Constraint)
// ----------------------------------------------------------------------------
//
// Types are NOT runtime values.
//
// Therefore:
//   - Types must never be passed as runtime arguments
//   - Types only exist in CTValue form
//
// Currently:
//   baseType(int) works because evaluation happens at compile time
//
// Future:
//   May restrict to:
//       baseType<int>()
//
// But for now:
//   - type-as-expression is allowed
//   - must resolve via evalCT
//
// ----------------------------------------------------------------------------
// 9. Type Transformations
// ----------------------------------------------------------------------------
//
// Type transformations are just comptime functions:
//
//   comptime fn unwrapReactive(T: Type) -> Type
//   comptime fn returnType(T: Type) -> Type
//   comptime fn baseType(T: Type) -> Type
//
// No special type-level syntax (no TS-style ReturnType<T>, no keyof).
//
// ----------------------------------------------------------------------------
// 10. Generics + Expressions
// ----------------------------------------------------------------------------
//
// Generics accept expressions that evaluate to types:
//
//   Foo<int>
//   Foo<typeof(x)>
//   Foo<underlyingType(typeof(x))>
//
// Internally:
//   - generic arguments are evaluated via evalCT
//   - must produce TypeInfo
//
// ----------------------------------------------------------------------------
// 11. Reflection
// ----------------------------------------------------------------------------
//
// Types expose metadata:
//
//   typeof(value).fields
//   typeof(value).category
//
// These return CTValues and can be used in comptime logic:
//
//   for comptime field in typeof(value).fields { ... }
//
// ----------------------------------------------------------------------------
// 12. Design Philosophy
// ----------------------------------------------------------------------------
//
// - One evaluation model: CTValue
// - No separate "type language"
// - No template metaprogramming system
// - No runtime reflection
//
// Instead:
//
//   Types are values at compile time
//   Expressions can produce types
//   Comptime functions transform types
//
// ----------------------------------------------------------------------------
// 13. Future Extensions (Planned, Not Required Now)
// ----------------------------------------------------------------------------
//
// - Optional compile-time execution of normal functions (purity-based)
// - Better purity analysis
// - More expressive type expressions (carefully expanded)
// - Possible syntactic sugar for type arguments
//
// ----------------------------------------------------------------------------
// Summary:
//
//   Types = CTValues
//   Expressions → CTValues
//   Comptime functions operate on CTValues
//   Type positions require CTValue(type)
//
// This keeps the system:
//   - extremely powerful
//   - simple to reason about
//   - free of C++/TypeScript complexity
//
// ============================================================================