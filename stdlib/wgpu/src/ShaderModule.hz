
export struct ShaderModuleDescriptor {
    debugLabel?: str;
    code: str;
}

fn toFFI(v: ShaderModuleDescriptor): ffi.WGPUShaderModuleDescriptor :: final {

    let source = ffi.WGPUShaderSourceWGSL {
        chain: {
            next: none,
            sType: ffi.WGPUSType_ShaderSourceWGSL,
        },
        code: toFFI(v.code),
    }

    let desc = ffi.WGPUShaderModuleDescriptor {
        nextInChain: none,
        label: toOptionalFFI(v.debugLabel),
    }
    __c__("desc->nextInChain = (void*)source;");

    return desc;
}

export struct ShaderModule {
    handle: mut ffi.WGPUShaderModuleImpl;
}

fn fromFFI(v: mut ffi.WGPUShaderModuleImpl): mut ShaderModule :: final {
    return ShaderModule {
        handle: v,
    };
}

fn toFFI(v: ShaderModule): mut ffi.WGPUShaderModuleImpl :: final {
    return v.handle;
}

export enum bitflag ShaderStage {
    None = 0,
    Vertex = 1,
    Fragment = 2,
    Compute = 4,
}

fn shaderStageFromFFI(v: ffi.WGPUShaderStage): ShaderStage :: final {
    do unsafe {
        let usage: ShaderStage = uninitialized; // This is a bitflag
        __c__("usage = (int)v;");
        return usage;
    };
}

fn toFFI(v: ShaderStage): ffi.WGPUShaderStage :: final {
    do unsafe {
        let usage: ffi.WGPUShaderStage = uninitialized; // This is a bitflag
        __c__("usage = (int)v;");
        return usage;
    };
}
