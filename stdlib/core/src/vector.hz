
export extern C noemit inline struct hzstd_vec2_t {
  x: real = 0.0;
  y: real = 0.0;

  constructor(x: real, y: real) {
    return hzstd_vec2_t {
      x: x,
      y: y,
    };
  }

  neg() {
    return hzstd_vec2_t(-this.x, -this.y);
  }

  add(other: hzstd_vec2_t) {
    return hzstd_vec2_t(this.x + other.x, this.y + other.y);
  }

  sub(other: hzstd_vec2_t) {
    return hzstd_vec2_t(this.x - other.x, this.y - other.y);
  }

  mul(v: real) {
    return hzstd_vec2_t(this.x * v, this.y * v);
  }

  div(v: real) {
    return hzstd_vec2_t(this.x / v, this.y / v);
  }

  length(): real {
    return math.sqrt(math.pow(this.x, 2.0) + math.pow(this.y, 2.0));
  }

  normalize() {
    return this.div(this.length());
  }

  dot(other: hzstd_vec2_t) {
    return this.x * other.x + this.y * other.y;
  }
}
export type Vec2 = hzstd_vec2_t;

export extern C noemit inline struct hzstd_vec2f_t {
  x: f32 = 0.0;
  y: f32 = 0.0;

  constructor(x: f32, y: f32) {
