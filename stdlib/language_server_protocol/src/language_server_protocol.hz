
export inline struct ContextArgs {
    exe: str;
    args: []str;
}

export inline struct Error {
    message: str;
}

export inline struct LSPError {
    code: int;
    message: str;
}

export struct LSPResponse {
    jsonrpc: str;
    method?: str;
    id?: int;
    result?: json.Node;
    params?: json.Node;
    error?: LSPError;
}

export struct LSPRequest<Params> {
    id?: int;
    jsonrpc: str;
    method: str;
    params: Params;
}

struct LSPInitializeParams {
    processId: int;

    struct ClientInfo {
        name: str;
        version?: str;
    };
    // Union<ClientInfo, Null> clientInfo;
    // Union<String, Null> locale;

    struct InitializationOptions {
        struct Plugin {
            name: str;
            location: str;
            languages: []str;
        };
        plugins: []Plugin;

        struct TypeScript {
            tsdk: str;
        };
        typescript?: TypeScript;
    };
    initializationOptions: InitializationOptions;

    rootUri: str;

    struct Capabilities {};
    capabilities: Capabilities;

    struct WorkspaceFolder {
        uri: str;
        name: str;
    };
    workspaceFolders?: []WorkspaceFolder;
};

export struct Context {
    _args: ContextArgs;
    _serverProcess: process.Process;
    _running: bool;

    initResponse: rx.ShallowReactive<LSPInitResponse | none>;
    _inputBuffer: str = "";

    _logAllRequests: bool = true;

    struct PendingRequest {
        requestId: int;
        successCallback: (response: json.Node) => none;
        errorCallback: (error: LSPError) => none;
    }
    _pendingRequests: []PendingRequest = [];
    _nextId: int = 0;

    fn constructor(_args: ContextArgs): Result<Context, Error> {
        let _serverProcess = process.spawn(_args.exe, _args.args);
        if !_serverProcess {
            return Error { 
                message: f"Server failed to launch: Exit code {_serverProcess}",
            };
        }

        let context = Context {
            _args: _args,
            _serverProcess: _serverProcess,
            _running: true,
            initResponse: rx.shallowReactive<LSPInitResponse | none>(none),
        };

        context.sendRequest<LSPInitializeParams, LSPInitResponse>("initialize", {
            processId: 0,
            workspaceFolders: [
                {
                    uri: "file:///home/fzachs/Projects/technicalsketcher.web",
                    name: "technicalsketcher.web"
                }
            ],
            capabilities: {},
            initializationOptions: {
                plugins: [
                    {
                        name: "@vue/typescript-plugin",
                        location: "/home/fzachs/Projects/CodeEditor/node_modules/@vue/typescript-plugin",
                        languages: ["vue"],
                    }
                ],
                typescript: {
                    tsdk: "/home/fzachs/Projects/haze/codeeditor/syntax-engine/node_modules/typescript/lib",
                }
            },
            rootUri: "file:///home/fzachs/Projects/technicalsketcher.web",
        }, (value: Result<LSPInitResponse, LSPError>) => {
            assert(value);
            context.initResponse := value;
        });

        context.sendNotification<LSPInitializedNotification>("initialized", {});

        return context;
    }

    fn loop() {
        let stderr = this._serverProcess.readStderr();
        if stderr.length > 0 {
            fmt.println("LSP Error: ", stderr);
        }

        let stdout = this._serverProcess.readStdout();
        if stdout.length > 0 {
            this._processStdout(stdout);
        }
    }

    fn sendRequest<TParams, TResponse>(method: str, params: TParams, onReceive: (value: Result<TResponse, LSPError>) => none) {
        assert(this._running);
        let id = this._nextId++;
        let request = json.stringify(LSPRequest<TParams> {
            id: id,
            jsonrpc: "2.0",
            method: method,
            params: params,
        });

        this._pendingRequests.push({
            requestId: id,
            successCallback: (response: json.Node) => {
                let result = json.parse<TResponse>(response);
                if !result {
                    fmt.println("Invalid LSP response: ", result);
                    return;
                }
                onReceive(Result<TResponse, LSPError>.Ok(result));
            },
            errorCallback: (error: LSPError) => {
                onReceive(Result<TResponse, LSPError>.Err(error));
            },
        });

        this.writeRequest(request);
        return id;
    }

    fn writeRequest(request: str) {
        if this._logAllRequests {
            fmt.println(f" -> {request}");
        }
        this._serverProcess.writeStdin(f"Content-Length: {request.length}\r\n\r\n{request}");
    }

    fn sendNotification<TParams>(method: str, params: TParams) {
        assert(this._running);
        let request = json.stringify(LSPRequest<TParams> {
            jsonrpc: "2.0",
            method: method,
            params: params,
        });
        this.writeRequest(request);
    }

    fn sendDocumentHoverRequest(filepath: str, line: int, character: int, callback: (response: Result<LSPDocumentHoverResponse, LSPError>) => none) {
        this.sendRequest<LSPDocumentHoverRequestParams, LSPDocumentHoverResponse>("textDocument/hover", {
            textDocument: {
                uri: f"file://{filepath}",
            },
            position: {
                line: line,
                character: character,
            },
        }, callback);
    }


    fn sendDocumentPublishDiagnosticsNotifications(filepath: str, languageId: str, version: int, fileContent: str) {
        // this.sendNotification<LSPOpenDocumentRequestParams>("textdocument/publishDiagnostics", {
        //     uri: f"file://{filepath}",
        //     diagnostics: [
        //         {
        //             range: {
        //                 start: { line: ,  }
        //             }
        //         }
        //     ]
        // });
    }

    fn sendDocumentOpenNotification(filepath: str, languageId: str, version: int, fileContent: str) {
        this.sendNotification<LSPOpenDocumentRequestParams>("textDocument/didOpen", {
            textDocument: {
                uri: f"file://{filepath}",
                languageId: languageId,
                version: version,
                text: fileContent,
            }
        });
    }

    fn _processStdout(stdout: str) {
        this._inputBuffer = this._inputBuffer + stdout;

        let contentLengthText = "Content-Length: ";
        if this._inputBuffer.length > 0 && !this._inputBuffer.startsWith(contentLengthText) {
            sys.panic(f"LSP: Input Buffer must never start with something other than '{contentLengthText}'");
        }

        let separator = "\r\n\r\n";
        let separatorIndex = find(this._inputBuffer, separator);
        if !separatorIndex {
            return none;
        }

        let numberLength = separatorIndex;
        let numberString = this._inputBuffer.slice(contentLengthText.length, separatorIndex);
        let contentLength = strToInt(numberString);
        if !contentLength {
            fmt.println("LSP Response: Failed to parse content length");
            return none;
        }
        let headerLength = separatorIndex + separator.length;
        let totalPacketLength = headerLength + contentLength;

        if this._inputBuffer.length < totalPacketLength {
            return none;
        }

        // Extract response and shift remaining packet forward
        let response = this._inputBuffer.slice(headerLength, headerLength + contentLength);
        let remainingPacket = this._inputBuffer.slice(totalPacketLength);
        this._inputBuffer = remainingPacket;

        this._processResponse(response);
    }

    fn _dispatchNotificationResponse(method: str, response: json.Node) {
        if method == "tsserver/request" {
            // TODO: Implement this. This is a custom extension implemented by the Vue LSP
            // fmt.println(json.stringify(response));
        }
        else {
            fmt.println(f"Unsupported method '{method}'");
        }
    }

    fn _dispatchResponse(requestId: int, response: json.Node | LSPError) {
        let found = false;
        for entry in this._pendingRequests {
            if entry.requestId == requestId {
                found = true;
            }
        }

        // Doing the loop twice because otherwise we would reconstruct the pending array every frame while
        // nothing changed which is incredibly wasteful
        if found {
            let remainingRequests: []PendingRequest = [];
            for entry in this._pendingRequests {
                if entry.requestId == requestId {
                    if response is json.Node {
                        entry.successCallback(response);
                    }
                    else {
                        entry.errorCallback(response);
                    }
                }
                else {
                    remainingRequests.push(entry);
                }
            }
            this._pendingRequests = remainingRequests;
        }
    }

    fn _processResponse(response: str) {
        let result = json.parse<LSPResponse>(response);
        if !result {
            fmt.println(f"Json response failed to parse: {result}");
            return;
        }
        if result.jsonrpc != "2.0" {
            fmt.println(f"LSP: Response invalid: Expected jsonrpc version 2.0, but received {result.jsonrpc}");
            return;
        }

        if result.id is none {
            assert(result.params, "Notifications require params obj");
            assert(result.method, "Notifications require a method");
            this._dispatchNotificationResponse(result.method, result.params);
            return;
        }

        if !result.result && !result.error {
            fmt.println(response);
            fmt.println(f"LSP: Response invalid: Result and Error fields are both missing");
            return;
        }

        if result.result && result.error {
            fmt.println(f"LSP: Response invalid: Result and Error fields both exist");
            return;
        }

        if this._logAllRequests {
            fmt.println(f" <- {json.stringify(response)}");
        }

        if result.error {
            this._dispatchResponse(result.id, result.error);
            return;
        }

        assert(result.result);
        this._dispatchResponse(result.id, result.result);
    }

    fn stop() {
        assert(this._running);
        this._serverProcess.join();
        this._running = false;
    }
}

