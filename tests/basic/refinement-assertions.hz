
fn union_value() {
    let b = Box<int>(42);
    assert(b.value is int);
    (() => {
        b.value = 3.14;
    })();

    fmt.println(f"Value = {b.value}");
    return 0;
}

fn union_union() {
    let b: int | real | null = 42;
    assert(b is not null);
    (() => {
        b = null;
    })();

    fmt.println(f"Value = {b}");
    return 0;
}

fn integer() {
    let b: u16 = 255;
    assert(b <= u8.max);
    (() => {
        b++;
    })();

    fmt.println(f"Value = {b as u8}");
    return 0;
}

fn main(): int {
    // union_value();
    // union_union();
    // integer();
    return 0;
}