
fn union_value() {
    let b = Box<int | real>(42);
    assert(b.value is int);
    (() => {
        b.value = 3.14;
    })();

    fmt.println(f"Value = {b.value}");
    return 0;
}

fn union_union() {
    let b: int | real | null = 42;
    assert(b is not null);
    (() => {
        b = null;
    })();

    // TODO: Support formatting unions, by using compile time features
    // to choose the currently active union variant
    if b is int {
        fmt.println(f"Value = {b}");
    }
    else {
        fmt.println(f"Value = {b}");
    }
    return 0;
}

fn integer() {
    let b: u16 = 255;
    assert(b <= u8.max);
    (() => {
        b++;
    })();

    fmt.println(f"Value = {b as u8}");
    return 0;
}

